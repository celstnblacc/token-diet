#!/usr/bin/env bash
# token-diet project pre-commit hook
# Run by ~/.githooks/pre-commit (global hook delegates here)
# ShipGuard SAST + secret detection are handled by the global hook — not here.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Verify install script is executable and passes a dry-run
echo "token-diet: verifying install.sh dry-run..."
bash "$REPO_ROOT/scripts/install.sh" --dry-run --skip-tests 2>&1 | tail -5

# Run bash tests if bats is available
if command -v bats &>/dev/null && [ -d "$REPO_ROOT/tests" ]; then
  echo "token-diet: running bats tests..."
  bats "$REPO_ROOT/tests/"*.bats
fi

# Run Python tests if pytest is available
if command -v python3 &>/dev/null && python3 -m pytest --version &>/dev/null 2>&1; then
  if [ -d "$REPO_ROOT/tests" ] && ls "$REPO_ROOT/tests"/test_*.py &>/dev/null 2>&1; then
    echo "token-diet: running pytest..."
    python3 -m pytest "$REPO_ROOT/tests/" -q
  fi
fi

# Run PowerShell tests if pwsh + Pester are available
if command -v pwsh &>/dev/null && pwsh -NoProfile -Command "Get-Module -ListAvailable Pester" &>/dev/null 2>&1; then
  if ls "$REPO_ROOT/tests/"*.Tests.ps1 &>/dev/null 2>&1; then
    # Skip slow PowerShell tests on non-Windows by default to save time
    if [[ "$(uname -s)" != "CYGWIN"* && "$(uname -s)" != "MINGW"* && "$(uname -s)" != "MSYS"* ]] && [ "${RUN_SLOW_TESTS:-0}" != "1" ]; then
      echo "token-diet: skipping slow Pester tests (set RUN_SLOW_TESTS=1 to run)."
    else
      echo "token-diet: running Pester tests..."
      pwsh -NoProfile -Command "
        \$env:USERPROFILE = if (\$env:USERPROFILE) { \$env:USERPROFILE } else { \$env:HOME }
        \$env:APPDATA     = if (\$env:APPDATA)     { \$env:APPDATA     } else { \$env:HOME }
        Import-Module Pester -Force
        \$cfg = New-PesterConfiguration
        \$cfg.Run.Path = '$REPO_ROOT/tests'
        \$cfg.Run.Exit = \$true
        \$cfg.Output.Verbosity = 'Minimal'
        Invoke-Pester -Configuration \$cfg
      "
    fi
  fi
fi

# Documentation Sync Check
# Ensure all primary subcommands are mentioned in README.md
echo "token-diet: verifying documentation sync..."
# Extract command names from help output
COMMANDS=$(bash "$REPO_ROOT/scripts/token-diet" --help | sed -n '/COMMANDS/,/TOOLS/p' | grep '^  [a-z]' | awk '{print $1}')
MISSING=()
for CMD in $COMMANDS; do
  # Skip internal/redundant/low-level commands to avoid noise
  if [[ "$CMD" =~ ^(gain|service|upstream|version|update|serena-gc|strip)$ ]]; then continue; fi
  
  # Look for "token-diet <cmd>" in any code context or bold text
  if ! grep -qiE "(\`token-diet $CMD|token-diet $CMD\`|\*\*token-diet $CMD\*\*)" "$REPO_ROOT/README.md"; then
    MISSING+=("$CMD")
  fi
done

if [ ${#MISSING[@]} -ne 0 ]; then
  echo -e "\033[0;31m[BLOCKED] Documentation out of sync!\033[0m"
  echo "The following subcommands are in code but not documented in README.md:"
  for M in "${MISSING[@]}"; do echo "  - $M"; done
  echo -e "\nUpdate README.md before committing."
  exit 1
fi

echo "token-diet: pre-commit checks passed."
