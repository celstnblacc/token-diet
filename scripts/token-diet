#!/usr/bin/env bash
# token-diet — token optimization stack dashboard
# Shows combined token savings and health across RTK + tilth + Serena.
#
# Usage:
#   token-diet gain           Show token savings dashboard (default)
#   token-diet health         Quick health check: tools + MCP hosts
#   token-diet version        Show versions of all three tools
#   token-diet verify         Re-run installation verification
#   token-diet uninstall      Remove all token-diet components
#   token-diet --help         Show this help

set -euo pipefail

readonly TD_VERSION="1.4.3"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Colors -------------------------------------------------------------------
if [ -t 1 ]; then
  GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
  GREEN=''; YELLOW=''; RED=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

ok()   { echo -e "  ${GREEN}✓${NC}  $*"; }
warn() { echo -e "  ${YELLOW}!${NC}  $*"; }
miss() { echo -e "  ${RED}✗${NC}  $*"; }
dim()  { echo -e "${DIM}$*${NC}"; }

# --- Helpers ------------------------------------------------------------------
human_tokens() {
  local n=$1
  if   [ "$n" -ge 1000000 ]; then printf "%.1fM" "$(echo "$n / 1000000" | bc -l)"
  elif [ "$n" -ge 1000 ];    then printf "%.1fK" "$(echo "$n / 1000"    | bc -l)"
  else printf "%d" "$n"
  fi
}

human_ms() {
  local ms=$1
  if   [ "$ms" -ge 3600000 ]; then printf "%dh %dm" "$((ms/3600000))" "$(( (ms%3600000)/60000 ))"
  elif [ "$ms" -ge 60000 ];   then printf "%dm %ds" "$((ms/60000))" "$(( (ms%60000)/1000 ))"
  elif [ "$ms" -ge 1000 ];    then printf "%ds"      "$((ms/1000))"
  else printf "%dms" "$ms"
  fi
}

bar() {
  local pct=${1%.*}   # integer part of percentage
  local width=20
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  printf '%0.s█' $(seq 1 "$filled") 2>/dev/null || printf '%*s' "$filled" | tr ' ' '█'
  printf '%0.s░' $(seq 1 "$empty")  2>/dev/null || printf '%*s' "$empty"  | tr ' ' '░'
}

check_cmd() { command -v "$1" &>/dev/null; }

# Extract the configured command for [mcp_servers.<tool>] from Codex TOML.
codex_mcp_command() {
  local tool="$1"
  local codex="$HOME/.codex/config.toml"
  check_cmd python3 || return 1
  [ -f "$codex" ] || return 1

  python3 - "$codex" "$tool" << 'PY'
import pathlib, re, sys

cfg_path = pathlib.Path(sys.argv[1])
tool = sys.argv[2]
text = cfg_path.read_text()
block = re.search(r'(?ms)^\[mcp_servers\.%s\]\s*(.*?)(?=^\[|\Z)' % re.escape(tool), text)
if not block:
    raise SystemExit(1)
command = re.search(r'(?m)^command\s*=\s*["\']([^"\']+)["\']\s*$', block.group(1))
if not command:
    raise SystemExit(1)
print(command.group(1))
PY
}

mcp_command_exists() {
  local command_value="$1"
  if [[ "$command_value" == */* ]]; then
    [ -x "$command_value" ]
  else
    check_cmd "$command_value"
  fi
}

# Read minimum required version for a tool from config/compat.json.
# Outputs "0.0.0" if the file is absent or the tool is not listed.
_compat_min() {
  local tool="$1"
  local compat_file="$SCRIPT_DIR/../config/compat.json"
  if [ ! -f "$compat_file" ]; then echo "0.0.0"; return; fi
  python3 -c "
import json, sys
try:
    d = json.load(open('$compat_file'))
    print(d['tools']['$tool']['min'])
except Exception:
    print('0.0.0')
" 2>/dev/null || echo "0.0.0"
}

# Return 0 (true) when \$installed >= \$min_required (semver comparison).
# Pre-release suffixes like -mock, -beta are stripped before comparison.
_semver_ok() {
  local installed="$1" min="$2"
  python3 - "$installed" "$min" << 'PY'
import sys, re
def parse(v):
    v = re.sub(r'[^0-9.].*$', '', v)   # strip -mock, -beta, -rc1, etc.
    parts = v.split('.')
    try:
        return tuple(int(x) for x in (parts + ['0', '0', '0'])[:3])
    except ValueError:
        return (0, 0, 0)
try:
    sys.exit(0 if parse(sys.argv[1]) >= parse(sys.argv[2]) else 1)
except Exception:
    sys.exit(0)   # unparseable → assume OK
PY
}

codex_mcp_command_issue() {
  local tool="$1"
  local command_value
  command_value="$(codex_mcp_command "$tool")" || return 0
  if ! mcp_command_exists "$command_value"; then
    echo "Codex ${tool} MCP command missing: ${command_value}"
  fi
  return 0
}

# Scan common MCP config files for a tool name
hosts_registered() {
  local tool="$1"
  local found=()
  local configs=(
    "$HOME/.claude/settings.json"
    "$HOME/Library/Application Support/Claude/claude_desktop_config.json"
    "$HOME/.config/Claude/claude_desktop_config.json"
    "$HOME/.opencode.json"
  )
  for cfg in "${configs[@]}"; do
    [ -f "$cfg" ] || continue
    if python3 -c "import json,sys; d=json.load(open('$cfg')); exit(0 if any('$tool' in k.lower() for k in d.get('mcpServers',{}).keys()) else 1)" 2>/dev/null; then
      case "$cfg" in
        *"Application Support"*) found+=("claude-desktop") ;;
        *settings.json*)         found+=("claude-code") ;;
        *opencode*)              found+=("opencode") ;;
      esac
    fi
  done
  # Codex
  codex_mcp_command "$tool" >/dev/null 2>&1 && found+=("codex")
  # VS Code
  local vscode_cfg="$HOME/.config/Code/User/settings.json"
  [ -f "$vscode_cfg" ] && grep -q "$tool" "$vscode_cfg" 2>/dev/null && found+=("vscode")

  if [ ${#found[@]} -gt 0 ]; then
    echo "${found[*]}" | tr ' ' ','
  else
    echo "none"
  fi
}

# --- Commands -----------------------------------------------------------------
cmd_gain() {
  echo -e "\n${BOLD}=== token-diet gain ===${NC}\n"

  # --- RTK -------------------------------------------------------------------
  echo -e "${BOLD}RTK${NC} ${DIM}— command output compression${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"

  if check_cmd rtk && rtk gain --help &>/dev/null 2>&1; then
    local json
    json=$(rtk gain --format json 2>/dev/null)
    local cmds saved input pct ms
    read -r cmds input saved pct ms <<< "$(echo "$json" | python3 -c "
import sys,json
d=json.load(sys.stdin)['summary']
print(d['total_commands'],d['total_input'],d['total_saved'],round(d['avg_savings_pct'],1),d['total_time_ms'])")"

    printf "  %-22s %s\n"  "Commands filtered:"  "$cmds"
    printf "  %-22s %s\n"  "Tokens in:"          "$(human_tokens "$input")"
    printf "  %-22s %s\n"  "Tokens saved:"        "$(human_tokens "$saved")  (${pct}%)"
    printf "  %-22s %s\n"  "Exec time:"           "$(human_ms "$ms")"
    echo -e "  Efficiency:  ${CYAN}$(bar "$pct")${NC}  ${BOLD}${pct}%${NC}"
    local rtk_ver; rtk_ver=$(rtk --version 2>/dev/null | awk '{print $2}')
    ok "RTK ${rtk_ver} — active"
  else
    miss "RTK not installed  →  run: bash install.sh --rtk-only"
  fi

  echo ""

  # --- tilth -----------------------------------------------------------------
  echo -e "${BOLD}tilth${NC} ${DIM}— AST-aware code reading (tree-sitter)${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"
  echo -e "  ${DIM}Note: tilth reduces prompt size — not tracked per-command${NC}"

  if check_cmd tilth; then
    local tv; tv=$(tilth --version 2>/dev/null | awk '{print $2}')
    local th; th=$(hosts_registered "tilth")
    printf "  %-22s %s\n" "Version:"   "$tv"
    printf "  %-22s %s\n" "MCP hosts:" "$th"
    ok "tilth ${tv} — active"
  else
    miss "tilth not installed  →  run: bash install.sh --tilth-only"
  fi

  echo ""

  # --- Serena ----------------------------------------------------------------
  echo -e "${BOLD}Serena${NC} ${DIM}— LSP symbol navigation${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"
  echo -e "  ${DIM}Note: Serena reduces prompt size — not tracked per-command${NC}"

  local serena_ok=false
  # Check uvx availability (online mode) or Docker image (local mode)
  if check_cmd uvx || docker image inspect token-diet/serena:latest &>/dev/null 2>&1; then
    serena_ok=true
  fi

  if $serena_ok; then
    local sh; sh=$(hosts_registered "serena")
    local mem_count=0 log_days=0
    [ -d "$HOME/.serena/memories" ] && mem_count=$(ls "$HOME/.serena/memories/" 2>/dev/null | wc -l | tr -d ' ')
    [ -d "$HOME/.serena/logs"     ] && log_days=$(ls "$HOME/.serena/logs/"     2>/dev/null | wc -l | tr -d ' ')
    printf "  %-22s %s\n" "MCP hosts:"    "$sh"
    printf "  %-22s %s\n" "Memories:"     "$mem_count files"
    printf "  %-22s %s\n" "Session logs:" "$log_days days"
    ok "Serena — active"
  else
    miss "Serena not installed  →  run: bash install.sh --serena-only"
  fi

  echo ""

  # --- Stack summary ---------------------------------------------------------
  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"
  local tools_active=0
  check_cmd rtk      && rtk gain --help &>/dev/null 2>&1 && (( tools_active++ )) || true
  check_cmd tilth    && (( tools_active++ )) || true
  $serena_ok         && (( tools_active++ )) || true

  printf "  %-22s %d/3\n" "Tools active:" "$tools_active"

  if check_cmd rtk && rtk gain --help &>/dev/null 2>&1; then
    printf "  %-22s %s  (%s%%)\n" "RTK tokens saved:" \
      "$(human_tokens "$saved")" "$pct"
    echo -e "\n  ${DIM}tilth + Serena savings are structural (smaller prompts, fewer turns)${NC}"
    echo -e "  ${DIM}and not individually tracked — but typically add 30-50% reduction${NC}"
  fi

  echo ""
  if [ "$tools_active" -eq 3 ]; then
    echo -e "  ${GREEN}${BOLD}Full stack active. Maximum token savings.${NC}"
  elif [ "$tools_active" -gt 0 ]; then
    echo -e "  ${YELLOW}${BOLD}Partial stack — run 'bash install.sh' to complete setup.${NC}"
  else
    echo -e "  ${RED}${BOLD}No tools installed — run 'bash install.sh' to get started.${NC}"
  fi
  echo ""
}

cmd_version() {
  echo -e "\n${BOLD}token-diet stack versions${NC}\n"

  if check_cmd rtk; then
    local rtk_ver; rtk_ver=$(rtk --version 2>/dev/null | awk '{print $2}')
    local rtk_min; rtk_min=$(_compat_min "rtk")
    if _semver_ok "$rtk_ver" "$rtk_min"; then
      ok "RTK    rtk ${rtk_ver}  (compat: OK)"
    else
      warn "RTK    rtk ${rtk_ver}  (compat: WARN — below min ${rtk_min}, upgrade: cargo install rtk)"
    fi
  else
    miss "RTK    not installed"
  fi

  if check_cmd tilth; then
    local tilth_ver; tilth_ver=$(tilth --version 2>/dev/null | awk '{print $2}')
    local tilth_min; tilth_min=$(_compat_min "tilth")
    if _semver_ok "$tilth_ver" "$tilth_min"; then
      ok "tilth  tilth ${tilth_ver}  (compat: OK)"
    else
      warn "tilth  tilth ${tilth_ver}  (compat: WARN — below min ${tilth_min}, upgrade: cargo install tilth)"
    fi
  else
    miss "tilth  not installed"
  fi

  check_cmd uvx    && ok "Serena (uvx available: $(uvx --version 2>/dev/null || echo 'ok'))" \
                  || { docker image inspect token-diet/serena:latest &>/dev/null 2>&1 \
                       && ok "Serena (Docker image: token-diet/serena:latest)" \
                       || miss "Serena not installed"; }
  echo ""
}

cmd_verify() {
  # Prefer install.sh next to this script (source tree or ~/.local/bin copy)
  local install_sh
  for install_sh in "$SCRIPT_DIR/install.sh" "$SCRIPT_DIR/token-diet-install.sh"; do
    if [[ -f "$install_sh" ]]; then
      bash "$install_sh" --verify
      return
    fi
  done

  # Inline fallback — used when running from ~/.local/bin (install.sh not copied there)
  local all_ok=true
  echo "=== Token Stack Verification ==="
  if command -v rtk &>/dev/null && rtk --version &>/dev/null 2>&1; then
    printf "  ${GREEN}✓${NC} RTK ........... %s\n" "$(rtk --version 2>/dev/null)"
  else
    printf "  ${YELLOW}✗${NC} RTK ........... not installed\n"; all_ok=false
  fi
  if command -v tilth &>/dev/null; then
    printf "  ${GREEN}✓${NC} tilth ......... %s\n" "$(tilth --version 2>/dev/null || echo 'installed')"
    local tilth_codex_issue; tilth_codex_issue=$(codex_mcp_command_issue "tilth")
    if [ -n "$tilth_codex_issue" ]; then
      printf "  ${YELLOW}✗${NC} %s\n" "$tilth_codex_issue"
      all_ok=false
    fi
  else
    printf "  ${YELLOW}✗${NC} tilth ......... not installed\n"; all_ok=false
  fi
  if docker image inspect token-diet/serena:latest &>/dev/null 2>&1; then
    printf "  ${GREEN}✓${NC} Serena ........ Docker image loaded\n"
  elif command -v uv &>/dev/null; then
    printf "  ${GREEN}✓${NC} Serena (uv) ... %s\n" "$(uv --version 2>/dev/null)"
  else
    printf "  ${YELLOW}✗${NC} Serena ........ not installed\n"; all_ok=false
  fi
  local serena_codex_issue; serena_codex_issue=$(codex_mcp_command_issue "serena")
  if [ -n "$serena_codex_issue" ]; then
    printf "  ${YELLOW}✗${NC} %s\n" "$serena_codex_issue"
    all_ok=false
  fi
  echo ""
  if $all_ok; then
    printf "  ${GREEN}✓${NC} All tools installed. Token diet active.\n"
    echo ""
  else
    printf "  ${YELLOW}⚠${NC}  Some tools or MCP registrations need attention.\n"
    echo ""
    return 1
  fi
}

cmd_dashboard() {
  local dashboard_bin
  # Prefer the installed copy, fall back to script-dir sibling
  if command -v token-diet-dashboard &>/dev/null; then
    dashboard_bin="$(command -v token-diet-dashboard)"
  else
    dashboard_bin="$SCRIPT_DIR/token-diet-dashboard"
  fi
  if [ ! -f "$dashboard_bin" ]; then
    echo "token-diet-dashboard not found — run: bash install.sh" >&2; exit 1
  fi
  exec python3 "$dashboard_bin" "$@"
}

cmd_health() {
  local issues=0
  echo -e "\n${BOLD}token-diet health${NC}\n"

  # RTK
  if check_cmd rtk && rtk gain --help &>/dev/null 2>&1; then
    local rtk_ver; rtk_ver=$(rtk --version 2>/dev/null | awk '{print $2}') || true
    ok "RTK ${rtk_ver}"
  else
    miss "RTK not found"
    issues=$(( issues + 1 ))
  fi

  # tilth
  if check_cmd tilth; then
    local tilth_ver; tilth_ver=$(tilth --version 2>/dev/null | awk '{print $2}') || true
    local tilth_hosts; tilth_hosts=$(hosts_registered "tilth")
    ok "tilth ${tilth_ver}  (hosts: ${tilth_hosts})"
    local tilth_codex_issue; tilth_codex_issue=$(codex_mcp_command_issue "tilth")
    if [ -n "$tilth_codex_issue" ]; then
      warn "$tilth_codex_issue"
      issues=$(( issues + 1 ))
    fi
  else
    miss "tilth not found"
    issues=$(( issues + 1 ))
  fi

  # Serena
  if check_cmd uvx || docker image inspect token-diet/serena:latest &>/dev/null 2>&1; then
    local serena_hosts; serena_hosts=$(hosts_registered "serena")
    ok "Serena  (hosts: ${serena_hosts})"
  else
    miss "Serena not found  (uvx or Docker required)"
    issues=$(( issues + 1 ))
  fi

  local serena_codex_issue; serena_codex_issue=$(codex_mcp_command_issue "serena")
  if [ -n "$serena_codex_issue" ]; then
    warn "$serena_codex_issue"
    issues=$(( issues + 1 ))
  fi

  echo ""
  if [ "$issues" -eq 0 ]; then
    echo -e "  ${GREEN}${BOLD}All tools healthy${NC}"
    echo ""
    return 0
  else
    echo -e "  ${YELLOW}${BOLD}${issues} issue(s) found — reinstall tools or repair MCP registrations${NC}"
    echo ""
    return 1
  fi
}

cmd_uninstall() {
  local uninstall_sh="$SCRIPT_DIR/uninstall.sh"
  if [ ! -f "$uninstall_sh" ]; then
    # Fallback: look next to the install script
    uninstall_sh="$(dirname "$SCRIPT_DIR/token-diet-install.sh")/uninstall.sh"
  fi
  if [ ! -f "$uninstall_sh" ]; then
    echo "Error: uninstall.sh not found. Re-run the installer to restore it:" >&2
    echo "  bash \$(dirname \$(which token-diet))/token-diet-install.sh" >&2
    exit 1
  fi
  bash "$uninstall_sh" "$@"
}

# --- Service (always-on dashboard daemon) -------------------------------------
cmd_service() {
  local sub="${1:-help}"
  local log_dir="$HOME/.local/share/token-diet"
  local log_file="$log_dir/dashboard.log"
  local dashboard_bin
  dashboard_bin="$(command -v token-diet-dashboard 2>/dev/null || echo "$SCRIPT_DIR/token-diet-dashboard")"
  local py_bin
  py_bin="$(command -v python3 2>/dev/null || command -v python 2>/dev/null || echo python3)"

  # ---- macOS launchd ---------------------------------------------------------
  _service_macos() {
    local plist="$HOME/Library/LaunchAgents/com.token-diet.dashboard.plist"
    case "$sub" in
      install)
        mkdir -p "$log_dir"
        mkdir -p "$(dirname "$plist")"
        # Resolve absolute python3 path (bypass pyenv shims which need shell init)
        local abs_py
        abs_py="$(python3 -c 'import sys; print(sys.executable)' 2>/dev/null || echo "$py_bin")"
        cat > "$plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.token-diet.dashboard</string>
    <key>ProgramArguments</key>
    <array>
        <string>${abs_py}</string>
        <string>${dashboard_bin}</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${PATH}</string>
        <key>HOME</key>
        <string>${HOME}</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${log_file}</string>
    <key>StandardErrorPath</key>
    <string>${log_file}</string>
</dict>
</plist>
PLIST
        launchctl bootout "gui/$(id -u)/com.token-diet.dashboard" 2>/dev/null || true
        launchctl bootstrap "gui/$(id -u)" "$plist"
        ok "Service installed and started (macOS launchd)"
        ok "Log: $log_file"
        ok "Dashboard: http://127.0.0.1:7384"
        ;;
      uninstall)
        launchctl bootout "gui/$(id -u)/com.token-diet.dashboard" 2>/dev/null || true
        rm -f "$plist"
        ok "Service removed (macOS launchd)"
        ;;
      start)
        launchctl kickstart -k "gui/$(id -u)/com.token-diet.dashboard" 2>/dev/null \
          || launchctl start com.token-diet.dashboard
        ok "Dashboard started"
        ;;
      stop)
        launchctl kill TERM "gui/$(id -u)/com.token-diet.dashboard" 2>/dev/null \
          || launchctl stop com.token-diet.dashboard
        ok "Dashboard stopped"
        ;;
      status)
        if launchctl print "gui/$(id -u)/com.token-diet.dashboard" &>/dev/null; then
          ok "Service registered (macOS launchd)"
          local pid
          pid=$(launchctl print "gui/$(id -u)/com.token-diet.dashboard" 2>/dev/null \
            | grep -E '^\s+pid\s*=' | awk '{print $3}' || true)
          [ -n "$pid" ] && ok "Running — PID $pid — http://127.0.0.1:7384" \
                        || warn "Registered but not running"
        else
          miss "Not installed — run: token-diet service install"
        fi
        ;;
      *)
        _service_usage ;;
    esac
  }

  # ---- Linux systemd (user) --------------------------------------------------
  _service_linux() {
    local unit_dir="$HOME/.config/systemd/user"
    local unit="$unit_dir/token-diet-dashboard.service"
    case "$sub" in
      install)
        mkdir -p "$unit_dir" "$log_dir"
        cat > "$unit" << UNIT
[Unit]
Description=token-diet browser dashboard
After=network.target

[Service]
ExecStart=${py_bin} ${dashboard_bin}
Restart=always
RestartSec=5
StandardOutput=append:${log_file}
StandardError=append:${log_file}

[Install]
WantedBy=default.target
UNIT
        systemctl --user daemon-reload
        systemctl --user enable --now token-diet-dashboard
        ok "Service installed and started (systemd user)"
        ok "Log: $log_file"
        ok "Dashboard: http://127.0.0.1:7384"
        ;;
      uninstall)
        systemctl --user disable --now token-diet-dashboard 2>/dev/null || true
        rm -f "$unit"
        systemctl --user daemon-reload
        ok "Service removed (systemd user)"
        ;;
      start)
        systemctl --user start token-diet-dashboard
        ok "Dashboard started"
        ;;
      stop)
        systemctl --user stop token-diet-dashboard
        ok "Dashboard stopped"
        ;;
      status)
        systemctl --user status token-diet-dashboard
        ;;
      *)
        _service_usage ;;
    esac
  }

  _service_usage() {
    cat << EOF
Usage: token-diet service <subcommand>

  install     Register dashboard as a system service (starts on login, auto-restarts)
  uninstall   Remove the service registration
  start       Start the dashboard service
  stop        Stop the dashboard service
  status      Show service status

Platforms:
  macOS   — launchd  (~/.local/share/token-diet/dashboard.log)
  Linux   — systemd user service
  Windows — use: token-diet.ps1 service install
EOF
    return 1
  }

  local os
  os="$(uname -s)"
  case "$os" in
    Darwin) _service_macos ;;
    Linux)  _service_linux ;;
    *)
      warn "Unsupported platform: $os"
      warn "On Windows use: token-diet.ps1 service install"
      exit 1
      ;;
  esac
}

# Fetch current RTK total_input tokens. Returns 0 if RTK unavailable.
_get_rtk_total() {
  if check_cmd rtk; then
    rtk gain --format json 2>/dev/null \
      | python3 -c "import json,sys; print(json.load(sys.stdin)['summary']['total_input'])" 2>/dev/null \
      || echo 0
  else
    echo 0
  fi
}

# Walk up from cwd toward $HOME looking for .token-budget. Echoes path if found.
find_budget_file() {
  local dir="$PWD"
  while [[ "$dir" == "$HOME"* ]]; do
    [ -f "$dir/.token-budget" ] && echo "$dir/.token-budget" && return 0
    [ "$dir" = "$HOME" ] && break
    dir="$(dirname "$dir")"
  done
  return 1
}

# Ensure ~/.token-budget exists (auto-create with defaults if missing).
# Echoes the path to the global budget file.
ensure_global_budget() {
  local global="$HOME/.token-budget"
  if [ ! -f "$global" ]; then
    local _baseline
    _baseline="$(_get_rtk_total)"
    python3 - "$global" "$_baseline" << 'PY'
import json, sys, pathlib, datetime
p = pathlib.Path(sys.argv[1])
p.write_text(json.dumps({
    "warn": 1500000, "hard": 0,
    "installed_at": datetime.date.today().isoformat(),
    "baseline_tokens": int(sys.argv[2]),
}, indent=2) + "\n")
PY
  fi
  echo "$global"
}

cmd_budget() {
  local subcmd="${1:-status}"
  shift || true

  case "$subcmd" in
    init)
      local is_global=false
      [ "${1:-}" = "--global" ] && is_global=true
      local target
      if $is_global; then target="$HOME/.token-budget"; else target="$PWD/.token-budget"; fi
      if [ -f "$target" ]; then
        warn ".token-budget already exists at $target"
        return 0
      fi
      local _baseline; _baseline=$(_get_rtk_total)
      python3 - "$target" "$_baseline" << 'PY'
import json, sys, datetime
d = {"warn": 1500000, "hard": 0,
     "installed_at": datetime.date.today().isoformat(),
     "baseline_tokens": int(sys.argv[2])}
with open(sys.argv[1], "w") as f:
    json.dump(d, f, indent=2)
    f.write("\n")
PY
      if $is_global; then
        ok "Created global $target  (warn: 1.5M, hard: unlimited, baseline: $(human_tokens "$_baseline"))"
      else
        ok "Created $target  (warn: 1.5M, hard: unlimited, baseline: $(human_tokens "$_baseline"))"
      fi
      local gitignore="$PWD/.gitignore"
      if [ -f "$gitignore" ]; then
        if ! grep -qxF '.token-budget' "$gitignore"; then
          printf '\n.token-budget\n' >> "$gitignore"
          ok "Added .token-budget to .gitignore"
        fi
      elif git rev-parse --git-dir &>/dev/null 2>&1; then
        printf '.token-budget\n' > "$gitignore"
        ok "Created .gitignore with .token-budget"
      fi
      ;;

    status)
      local budget_file global_file="$HOME/.token-budget"
      budget_file=$(find_budget_file) || budget_file=$(ensure_global_budget)

      # Detect if active file is a project override (not the global itself)
      local is_override=false
      if [ "$budget_file" != "$global_file" ]; then
        is_override=true
      fi

      _print_budget_section() {
        local file="$1" label="$2"
        local warn_t hard_t baseline
        read -r warn_t hard_t baseline <<< "$(python3 -c "
import json; d=json.load(open('$file'))
print(d.get('warn',1500000), d.get('hard',0), d.get('baseline_tokens',0))" 2>/dev/null)" \
          || { warn_t=1500000; hard_t=0; baseline=0; }
        local raw_total; raw_total=$(_get_rtk_total)
        local used=$(( raw_total - baseline ))
        [ "$used" -lt 0 ] && used=0

        local unlimited=false
        [ "$hard_t" -eq 0 ] && unlimited=true
        local remaining pct=0
        if $unlimited; then remaining="unlimited"
        else
          remaining=$(( hard_t - used ))
          [ "$hard_t" -gt 0 ] && pct=$(( used * 100 / hard_t ))
        fi

        echo -e "\n${BOLD}token-diet budget${NC}  ${DIM}${label}${NC}  ${DIM}($file)${NC}\n"
        printf "  %-20s %s\n" "Used:"      "$(human_tokens "$used")"
        printf "  %-20s %s\n" "Warn at:"   "$(human_tokens "$warn_t")"
        printf "  %-20s %s\n" "Hard stop:" "$(if $unlimited; then echo 'unlimited'; else human_tokens "$hard_t"; fi)"
        printf "  %-20s %s\n" "Remaining:" "$(if $unlimited; then echo 'unlimited'; else human_tokens "$remaining"; fi)"
        if ! $unlimited; then
          echo -e "  Burn-down:  ${CYAN}$(bar "$pct")${NC}  ${BOLD}${pct}%${NC}"
        fi
        echo ""

        if ! $unlimited && [ "$used" -ge "$hard_t" ]; then
          echo -e "  ${RED}${BOLD}HARD STOP — budget exhausted (${pct}%)${NC}\n"; return 3
        elif [ "$used" -ge "$warn_t" ]; then
          echo -e "  ${YELLOW}${BOLD}WARN — approaching warn threshold (${pct}%)${NC}\n"; return 2
        else
          echo -e "  ${GREEN}${BOLD}Budget OK${NC}\n"; return 0
        fi
      }

      if $is_override; then
        local _rc=0
        _print_budget_section "$budget_file" "[project]" || _rc=$?
        if [ -f "$global_file" ]; then
          local g_warn g_hard
          read -r g_warn g_hard <<< "$(python3 -c "
import json; d=json.load(open('$global_file'))
print(d.get('warn',1500000), d.get('hard',0))" 2>/dev/null)" \
            || { g_warn=1500000; g_hard=0; }
          echo -e "${DIM}  global ($global_file)${NC}"
          printf "  ${DIM}%-20s %s${NC}\n" "Warn at:"   "$(human_tokens "$g_warn")"
          printf "  ${DIM}%-20s %s${NC}\n" "Hard stop:" "$(if [ "$g_hard" -eq 0 ]; then echo 'unlimited'; else human_tokens "$g_hard"; fi)"
          echo ""
        fi
        return $_rc
      else
        local _rc=0
        _print_budget_section "$budget_file" "[global]" || _rc=$?
        return $_rc
      fi
      ;;

    *)
      echo "Usage: token-diet budget <init|status>" >&2
      return 1
      ;;
  esac
}

cmd_loops() {
  if ! check_cmd rtk || ! rtk gain --help &>/dev/null 2>&1; then
    echo -e "  ${RED}RTK not installed — loop detection requires RTK${NC}" >&2
    return 1
  fi

  local raw; raw=$(rtk gain 2>/dev/null) || true
  if [ -z "$raw" ]; then
    echo -e "  ${YELLOW}No RTK history yet${NC}"
    return 0
  fi

  local threshold=3
  local loops_found
  loops_found=$(python3 - "$raw" "$threshold" << 'PY'
import re, sys

def parse_saved(s):
    s = s.strip()
    if s.endswith('K'): return int(float(s[:-1]) * 1000)
    elif s.endswith('M'): return int(float(s[:-1]) * 1_000_000)
    elif re.match(r'^\d+$', s): return int(s)
    return 0

raw = sys.argv[1]
threshold = int(sys.argv[2])
pattern = re.compile(r'^\s*\d+\.\s+(.+?)\s{2,}(\d+)\s+([\d.]+[KM]?)\s+([\d.]+)%', re.MULTILINE)
for m in pattern.finditer(raw):
    cmd = m.group(1).rstrip()
    count = int(m.group(2))
    if count >= threshold:
        saved = parse_saved(m.group(3))
        pct = float(m.group(4))
        total_input = int(saved / (pct / 100)) if pct > 0 else saved
        wasted = total_input - saved
        print(f'{cmd}\t{count}\t{wasted}')
PY
  ) || true

  echo -e "\n${BOLD}=== token-diet loops ===${NC}\n"

  if [ -z "$loops_found" ]; then
    echo -e "  ${GREEN}No loops detected — all commands run < ${threshold} times${NC}"
    echo ""
    return 0
  fi

  echo -e "${BOLD}Repeated commands  ${DIM}(≥${threshold} runs — potential agent loops)${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..52})${NC}"
  while IFS=$'\t' read -r cmd count wasted; do
    echo -e "  ${RED}✗${NC}  ${BOLD}${cmd}${NC}  — ${count}x  (~$(human_tokens "$wasted") tokens lost to repetition)"
  done <<< "$loops_found"
  echo ""
  echo -e "  ${YELLOW}Tip: instruct your agent to cache results or use tilth for repeated reads${NC}"
  echo ""
  return 1
}

cmd_breakdown() {
  local limit=10
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="${2:-$limit}"; shift ;;
      *) ;;
    esac
    shift
  done

  if ! check_cmd rtk || ! rtk gain --help &>/dev/null 2>&1; then
    echo -e "  ${RED}RTK not installed — breakdown requires RTK${NC}" >&2
    return 1
  fi

  local raw; raw=$(rtk gain 2>/dev/null) || true
  if [ -z "$raw" ]; then
    echo -e "  ${YELLOW}No RTK history yet — run some commands first${NC}"
    return 0
  fi

  echo -e "\n${BOLD}=== token-diet breakdown ===${NC}\n"
  echo -e "${BOLD}Top commands by tokens saved${NC}  ${DIM}(limit: ${limit})${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..52})${NC}"

  python3 - "$raw" "$limit" << 'PY'
import re, sys

def parse_saved(s):
    s = s.strip()
    if s.endswith('K'): return int(float(s[:-1]) * 1000)
    elif s.endswith('M'): return int(float(s[:-1]) * 1_000_000)
    elif re.match(r'^\d+$', s): return int(s)
    return 0

raw = sys.argv[1]
limit = int(sys.argv[2])
pattern = re.compile(r'^\s*\d+\.\s+(.+?)\s{2,}(\d+)\s+([\d.]+[KM]?)\s+([\d.]+)%', re.MULTILINE)
rows = []
for m in pattern.finditer(raw):
    cmd = m.group(1).rstrip()
    count = int(m.group(2))
    saved = parse_saved(m.group(3))
    pct = float(m.group(4))
    total_input = int(saved / (pct / 100)) if pct > 0 else saved
    rows.append((cmd, count, saved, pct, total_input))

for i, (cmd, count, saved, pct, inp) in enumerate(rows[:limit], 1):
    saved_k = f"{saved/1000:.1f}K" if saved >= 1000 else str(saved)
    inp_k   = f"{inp/1000:.1f}K"   if inp   >= 1000 else str(inp)
    label = cmd[:34]
    print(f"  {i:>2}. {label:<36} {saved_k:>7} saved  {pct:>5.1f}%  ({count}x, {inp_k} in)")
PY

  echo ""
}

cmd_explain() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: token-diet explain <command>" >&2
    return 1
  fi

  if ! check_cmd rtk || ! rtk gain --help &>/dev/null 2>&1; then
    echo -e "  ${RED}RTK not installed — explain requires RTK${NC}" >&2
    return 1
  fi

  local raw; raw=$(rtk gain 2>/dev/null) || true
  if [ -z "$raw" ]; then
    echo -e "  ${YELLOW}No RTK history yet — run some commands first${NC}"
    return 1
  fi

  local result
  result=$(python3 - "$raw" "$target" << 'PY'
import re, sys

def parse_saved(s):
    s = s.strip()
    if s.endswith('K'): return int(float(s[:-1]) * 1000)
    elif s.endswith('M'): return int(float(s[:-1]) * 1_000_000)
    elif re.match(r'^\d+$', s): return int(s)
    return 0

raw = sys.argv[1]
target = sys.argv[2]
pattern = re.compile(r'^\s*\d+\.\s+(.+?)\s{2,}(\d+)\s+([\d.]+[KM]?)\s+([\d.]+)%', re.MULTILINE)
for m in pattern.finditer(raw):
    cmd = m.group(1).rstrip()
    if cmd != target:
        continue
    count = int(m.group(2))
    saved = parse_saved(m.group(3))
    pct = float(m.group(4))
    total_input = int(saved / (pct / 100)) if pct > 0 else saved
    out = total_input - saved
    print(f"cmd={cmd}")
    print(f"count={count}")
    print(f"input={total_input}")
    print(f"output={out}")
    print(f"saved={saved}")
    print(f"pct={pct}")
    sys.exit(0)
sys.exit(1)
PY
  ) || true

  if [ -z "$result" ]; then
    echo -e "  ${YELLOW}No data for '${target}' — not found in RTK history${NC}"
    return 1
  fi

  local cmd count inp out saved pct
  cmd=$(echo "$result"   | grep "^cmd="    | cut -d= -f2-)
  count=$(echo "$result" | grep "^count="  | cut -d= -f2-)
  inp=$(echo "$result"   | grep "^input="  | cut -d= -f2-)
  out=$(echo "$result"   | grep "^output=" | cut -d= -f2-)
  saved=$(echo "$result" | grep "^saved="  | cut -d= -f2-)
  pct=$(echo "$result"   | grep "^pct="    | cut -d= -f2-)

  echo -e "\n${BOLD}=== token-diet explain ===${NC}\n"
  echo -e "${BOLD}${cmd}${NC}  ${DIM}(${count} runs)${NC}"
  echo -e "${DIM}$(printf '%.0s─' {1..44})${NC}"
  printf "  %-20s %s\n" "Tokens in:"    "$(human_tokens "$inp")"
  printf "  %-20s %s\n" "Tokens out:"   "$(human_tokens "$out")"
  printf "  %-20s %s  (${pct}%%)\n" "Tokens saved:" "$(human_tokens "$saved")"
  echo -e "  Efficiency:  ${CYAN}$(bar "$pct")${NC}  ${BOLD}${pct}%${NC}"
  echo ""
}

cmd_route() {
  local task="${1:-}"
  if [[ -z "$task" ]]; then
    echo "Usage: token-diet route <task description>"
    exit 1
  fi

  local lower
  lower=$(echo "$task" | tr '[:upper:]' '[:lower:]')

  if [[ "$lower" =~ (rename|refactor|reference|diagnostic|navigate|symbol|lsp|find.*def|go.to) ]]; then
    echo -e "${BOLD}→ Serena${NC} (LSP navigation)"
    echo "  Best for: rename, refactor, find references, diagnostics, symbol search"
    echo "  Command:  use serena MCP tools (rename_symbol, find_referencing_symbols)"
  elif [[ "$lower" =~ (run|build|test|install|npm|cargo|make|git|docker|pip|exec|deploy) ]]; then
    echo -e "${BOLD}→ RTK${NC} (output compression)"
    echo "  Best for: CLI commands whose output would flood context"
    echo "  Command:  rtk <your-command>  (or let the Claude Code hook wrap it)"
  elif [[ "$lower" =~ (read|search|find|list|outline|grep|cat|show|view|open|import|deps) ]]; then
    echo -e "${BOLD}→ tilth${NC} (AST-aware reading)"
    echo "  Best for: reading files, searching symbols, exploring structure"
    echo "  Command:  use tilth MCP tools (tilth_read, tilth_search, tilth_files)"
  else
    echo -e "${BOLD}No clear match${NC} — all three tools may apply:"
    echo ""
    echo "  tilth   — reading/searching code (AST-aware, fast)"
    echo "  Serena  — renaming/navigating symbols (LSP-powered)"
    echo "  RTK     — running CLI commands (output compression)"
  fi
}

cmd_leaks() {
  if ! check_cmd rtk; then
    miss "RTK not installed — leaks detection requires RTK history"
    exit 1
  fi

  local raw
  raw=$(rtk gain 2>/dev/null) || { miss "RTK history unavailable"; exit 1; }

  local leaks
  leaks=$(python3 - "$raw" << 'PY'
import re, sys

def parse_saved(s):
    s = s.strip()
    if s.endswith('K'): return int(float(s[:-1]) * 1000)
    elif s.endswith('M'): return int(float(s[:-1]) * 1_000_000)
    elif re.match(r'^\d+$', s): return int(s)
    return 0

raw = sys.argv[1]
pattern = re.compile(r'^\s*\d+\.\s+(.+?)\s{2,}(\d+)\s+([\d.]+[KM]?)\s+([\d.]+)%', re.MULTILINE)
FILE_READ = re.compile(r'\b(?:rtk\s+)?(?:cat|head|tail|tilth\s+read|tilth_read)\s+(\S+\.\w+)')
found = []
for m in pattern.finditer(raw):
    cmd = m.group(1).rstrip()
    count = int(m.group(2))
    fm = FILE_READ.search(cmd)
    if fm and count >= 2:
        saved = parse_saved(m.group(3))
        pct = float(m.group(4))
        total_input = int(saved / (pct / 100)) if pct > 0 else saved
        found.append((fm.group(1), count, total_input))
found.sort(key=lambda x: x[1], reverse=True)
for f, cnt, tok in found:
    print(f"{f}\t{cnt}\t{tok}")
PY
)

  if [[ -z "$leaks" ]]; then
    ok "No leaks detected — no files read multiple times"
    exit 0
  fi

  echo -e "${BOLD}Context leaks — files read multiple times:${NC}"
  echo ""
  while IFS=$'\t' read -r filepath count total_input; do
    warn "$filepath  (${count}×, ~$(human_tokens "$total_input") tokens)"
  done <<< "$leaks"
  echo ""
  echo "  Tip: use tilth_read with offset/limit to read only changed sections"
  exit 1
}

cmd_test_first() {
  local file="${1:-}"
  if [[ -z "$file" ]]; then
    echo "Usage: token-diet test-first <file>"
    exit 1
  fi

  local basename="${file##*/}"
  local name="${basename%.*}"
  local ext="${basename##*.}"
  local dir="${file%/*}"
  [[ "$dir" == "$file" ]] && dir="."

  echo "Test candidates for ${BOLD}${file}${NC}:"
  echo ""

  case "$ext" in
    py)
      echo "  tests/test_${name}.py"
      echo "  test_${name}.py"
      echo "  ${dir}/test_${name}.py"
      ;;
    rs)
      echo "  tests/${name}_test.rs"
      echo "  tests/test_${name}.rs"
      echo "  ${dir}/${name}_test.rs  (inline #[cfg(test)] module)"
      ;;
    ts|tsx)
      echo "  ${dir}/${name}.test.ts"
      echo "  ${dir}/${name}.spec.ts"
      echo "  tests/${name}.test.ts"
      ;;
    js|jsx)
      echo "  ${dir}/${name}.test.js"
      echo "  ${dir}/${name}.spec.js"
      echo "  tests/${name}.test.js"
      ;;
    go)
      echo "  ${dir}/${name}_test.go"
      ;;
    *)
      echo "  tests/test_${name}.${ext}"
      echo "  ${dir}/test_${name}.${ext}"
      ;;
  esac

  echo ""
  echo "  Tip: read the test file first to understand expected behavior before the implementation"
}

cmd_strip() {
  local STATS=false
  local file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stats) STATS=true; shift ;;
      -*)      echo "Unknown option: $1"; echo "Usage: token-diet strip [--stats] <file>"; exit 1 ;;
      *)       file="$1"; shift ;;
    esac
  done

  if [[ -z "$file" ]]; then
    echo "Usage: token-diet strip [--stats] <file>"
    exit 1
  fi

  if [[ ! -f "$file" ]]; then
    echo "File not found: $file"
    exit 1
  fi

  local ext="${file##*.}"
  case "$ext" in
    js|ts|jsx|tsx|java|c|cpp|h|cs|go|swift|kt)
      # Strip // single-line comments
      local stripped
      stripped=$(python3 - "$file" << 'PY'
import sys, re
with open(sys.argv[1]) as f:
    content = f.read()
# Remove // line comments (not inside strings — best-effort)
lines = []
for line in content.splitlines():
    # Remove // comment (simple: not string-aware)
    cleaned = re.sub(r'\s*//.*$', '', line)
    lines.append(cleaned)
print('\n'.join(lines))
PY
)
      ;;
    *)
      # Default: strip # comments (Python, bash, ruby, etc.)
      local stripped
      stripped=$(python3 - "$file" << 'PY'
import sys, re
with open(sys.argv[1]) as f:
    lines = f.readlines()
out = []
for line in lines:
    # Remove full-line comments
    stripped = re.sub(r'^\s*#.*\n?', '', line)
    # Remove inline comments (not inside strings — best-effort)
    stripped = re.sub(r'\s+#[^!\n].*$', '', stripped.rstrip('\n'))
    out.append(stripped)
# Filter out lines that became empty due to comment removal
# but preserve blank lines that were originally blank
result = []
for orig, s in zip(lines, out):
    orig_stripped = orig.strip()
    if orig_stripped.startswith('#'):
        continue  # was a comment line — skip
    result.append(s)
print('\n'.join(result))
PY
)
      ;;
  esac

  if [[ "$STATS" == true ]]; then
    local orig_lines stripped_lines
    orig_lines=$(wc -l < "$file")
    stripped_lines=$(echo "$stripped" | wc -l)
    local saved=$(( orig_lines - stripped_lines ))
    local pct=0
    if [[ $orig_lines -gt 0 ]]; then
      pct=$(python3 -c "print(round($saved * 100 / $orig_lines, 1))")
    fi
    echo "$stripped"
    echo ""
    echo "Lines: $orig_lines → $stripped_lines  (saved $saved lines, ${pct}% reduction)"
  else
    echo "$stripped"
  fi
}

cmd_diff_reads() {
  local file="${1:-}"

  if [[ -z "$file" ]]; then
    echo "Usage: token-diet diff-reads <file>"
    exit 1
  fi

  if [[ ! -f "$file" ]]; then
    echo "File not found: $file"
    exit 1
  fi

  # Find repo root
  local repo_root
  repo_root=$(git -C "$(dirname "$file")" rev-parse --show-toplevel 2>/dev/null) || {
    echo "Not a git repository: $file"
    exit 1
  }

  # Get changed line ranges from git diff (unstaged + staged)
  local rel_path
  rel_path=$(realpath --relative-to="$repo_root" "$file" 2>/dev/null || python3 -c "
import os, sys
print(os.path.relpath(sys.argv[1], sys.argv[2]))" "$file" "$repo_root")

  # Combine staged and unstaged diffs
  local ranges
  ranges=$(git -C "$repo_root" diff HEAD -- "$rel_path" 2>/dev/null; \
           git -C "$repo_root" diff --cached -- "$rel_path" 2>/dev/null)

  if [[ -z "$ranges" ]]; then
    # No uncommitted changes — check last commit
    ranges=$(git -C "$repo_root" diff HEAD~1 HEAD -- "$rel_path" 2>/dev/null || true)
  fi

  if [[ -z "$ranges" ]]; then
    echo "No recent changes detected for: $rel_path"
    echo "Suggest reading the full file."
    exit 0
  fi

  # Parse @@ -a,b +c,d @@ hunks to extract new-file line ranges
  echo "Changed regions in $rel_path:"
  echo ""
  python3 - "$ranges" << 'PY'
import sys, re
content = sys.argv[1]
hunks = re.findall(r'@@ [^@]+ \+(\d+)(?:,(\d+))? @@', content)
if not hunks:
    print("  (no line range info available)")
else:
    for start_s, count_s in hunks:
        start = int(start_s)
        count = int(count_s) if count_s else 1
        end = start + count - 1
        if count == 0:
            print(f"  (deletion at line {start})")
        elif start == end:
            print(f"  line {start}")
        else:
            print(f"  lines {start}-{end}  (Read offset={start-1} limit={count})")
PY
}

cmd_serena_gc() {
  local force=false
  [[ "${1:-}" == "--force" ]] && force=true

  echo -e "\n${BOLD}token-diet serena-gc${NC}  — orphan/zombie process cleanup\n"

  # Patterns known to be spawned by Serena (MCP server + language servers)
  local -a patterns=("serena" "pylsp" "pyright-langserver" "jdtls" "rust-analyzer" "gopls" "typescript-language-server" "clangd" "solargraph")

  local -a found_pids=()
  local -a found_cmds=()

  for pat in "${patterns[@]}"; do
    local raw
    raw=$(pgrep -f "$pat" 2>/dev/null) || continue
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      [[ "$pid" == "$$" ]] && continue  # skip self
      local ppid cmd
      ppid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ') || continue
      cmd=$(ps -o args= -p "$pid" 2>/dev/null | cut -c1-72) || cmd="(unknown)"
      # Orphan = parent is init (ppid=1) or parent process is dead
      local is_orphan=false
      if [[ "$ppid" == "1" ]]; then
        is_orphan=true
      elif ! kill -0 "$ppid" 2>/dev/null; then
        is_orphan=true
      fi
      if $is_orphan; then
        found_pids+=("$pid")
        found_cmds+=("$cmd")
      fi
    done <<< "$raw"
  done

  if [[ ${#found_pids[@]} -eq 0 ]]; then
    ok "No orphaned Serena or language server processes found"
    echo ""
    return 0
  fi

  echo -e "  ${YELLOW}${BOLD}${#found_pids[@]} orphaned process(es) found:${NC}"
  echo ""
  for i in "${!found_pids[@]}"; do
    printf "  ${RED}✗${NC}  PID %-8s %s\n" "${found_pids[$i]}" "${found_cmds[$i]}"
  done
  echo ""

  if $force; then
    # Graceful SIGTERM first, then SIGKILL after 2s
    for pid in "${found_pids[@]}"; do
      kill -TERM "$pid" 2>/dev/null || true
    done
    sleep 2
    local killed=0
    for pid in "${found_pids[@]}"; do
      if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
        killed=$(( killed + 1 ))
      fi
    done
    ok "Sent SIGTERM to ${#found_pids[@]} process(es)$([ $killed -gt 0 ] && echo ", SIGKILL to ${killed} that did not exit")"
  else
    echo -e "  Run ${BOLD}token-diet serena-gc --force${NC} to terminate them"
  fi
  echo ""
}

# --- RTK toggle ---------------------------------------------------------------
RTK_DISABLED_FLAG="$HOME/.config/token-diet/rtk-disabled"
RTK_HOOK="$HOME/.claude/hooks/rtk-rewrite.sh"

_patch_rtk_hook() {
  # Inject sentinel-file check into the Claude Code RTK hook (idempotent).
  # Safe to call multiple times — bails out if already patched.
  [ -f "$RTK_HOOK" ] || return 0
  grep -q "rtk-disabled" "$RTK_HOOK" && return 0

  local tmp
  tmp="$(mktemp)"
  awk '
    /^if ! command -v jq/ && !patched {
      print "# Temporary disable (token-diet no-rtk / token-diet use-rtk)"
      print "if [ -f \"$HOME/.config/token-diet/rtk-disabled\" ]; then exit 0; fi"
      print ""
      patched=1
    }
    { print }
  ' "$RTK_HOOK" > "$tmp" && mv "$tmp" "$RTK_HOOK"
}

cmd_no_rtk() {
  mkdir -p "$(dirname "$RTK_DISABLED_FLAG")"
  touch "$RTK_DISABLED_FLAG"
  _patch_rtk_hook
  echo -e "${BOLD}[ok]${NC}  RTK disabled — commands pass through unfiltered"
  echo      "      Re-enable: token-diet use-rtk"
  if ! grep -q "rtk-disabled" "$RTK_HOOK" 2>/dev/null; then
    echo -e "${YELLOW}[warn]${NC} RTK hook not found at $RTK_HOOK"
    echo      "       Sentinel file created; hook bypass will apply once hook is installed."
  fi
}

cmd_use_rtk() {
  if [ ! -f "$RTK_DISABLED_FLAG" ]; then
    echo -e "${BOLD}[ok]${NC}  RTK is already enabled"
    return 0
  fi
  rm -f "$RTK_DISABLED_FLAG"
  echo -e "${BOLD}[ok]${NC}  RTK re-enabled — commands filtered for token savings"
}

cmd_repair() {
  local dry_run=false json_mode=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      --json)    json_mode=true; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local repairs=0 failures=0
  local -a repaired=() failed=() skipped=()
  _repaired() { repaired+=("$1"); repairs=$(( repairs + 1 )); }
  _failed()   { failed+=("$1");   failures=$(( failures + 1 )); }
  _skipped()  { skipped+=("$1"); }

  $json_mode || {
    echo -e "\n${BOLD}token-diet repair${NC}"
    $dry_run && echo -e "${DIM}  Dry-run mode — no changes will be made${NC}"
    echo ""
  }

  # ── 1. RTK hooks ─────────────────────────────────────────────────────────
  if check_cmd rtk && rtk --version &>/dev/null 2>&1; then
    local rtk_show; rtk_show=$(rtk init --show 2>/dev/null || echo "")
    local rtk_has_issues=false
    local _line
    while IFS= read -r _line; do
      case "$_line" in \[warn\]*|\[FAIL\]*) rtk_has_issues=true ;; esac
    done <<< "$rtk_show"

    if $rtk_has_issues; then
      if $dry_run; then
        $json_mode || warn "RTK hooks: would run 'rtk init -g --auto-patch'"
        _skipped "RTK hooks: dry-run — would run rtk init -g --auto-patch"
      else
        if rtk init -g --auto-patch &>/dev/null 2>&1; then
          $json_mode || ok "RTK hooks repaired"
          _repaired "RTK hooks: ran rtk init -g --auto-patch"
        else
          $json_mode || miss "RTK hooks: repair failed — run 'rtk init -g --auto-patch' manually"
          _failed "RTK hooks: rtk init -g --auto-patch failed"
        fi
      fi
    fi
  else
    _skipped "RTK hooks: rtk not installed"
  fi

  # ── 2. JSON MCP stale commands ───────────────────────────────────────────
  _repair_mcp_json() {
    local tool="$1" host_label="$2" cfg="$3"
    [ -f "$cfg" ] || return 0

    local registered
    registered=$(python3 - "$cfg" "$tool" << 'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    servers = d.get("mcpServers", {})
    key = next((k for k in servers if sys.argv[2].lower() in k.lower()), None)
    if key is None: sys.exit(1)
    print(servers[key].get("command", ""))
except Exception:
    sys.exit(1)
PY
    2>/dev/null) || return 0  # not registered — skip silently

    [ -n "$registered" ] || return 0
    mcp_command_exists "$registered" && return 0  # healthy

    # Stale command — find current path
    local new_path; new_path=$(command -v "$tool" 2>/dev/null || echo "")
    if [ -z "$new_path" ]; then
      $json_mode || miss "  ${host_label}  ${tool}: stale '${registered}' and '${tool}' not in PATH"
      _failed "${tool} ${host_label}: stale command and '${tool}' not in PATH — cannot repair"
      return 0
    fi

    if $dry_run; then
      $json_mode || warn "  ${host_label}  ${tool}: would update '${registered}' → '${new_path}'"
      _skipped "${tool} ${host_label}: dry-run — would update command to ${new_path}"
      return 0
    fi

    python3 - "$cfg" "$tool" "$new_path" << 'PY'
import json, sys, os
cfg_path, tool_name, new_cmd = sys.argv[1], sys.argv[2], sys.argv[3]
with open(cfg_path) as f:
    d = json.load(f)
servers = d.get("mcpServers", {})
key = next((k for k in servers if tool_name.lower() in k.lower()), None)
if key:
    servers[key]["command"] = new_cmd
tmp = cfg_path + ".tmp"
with open(tmp, "w") as f:
    json.dump(d, f, indent=2)
    f.write("\n")
os.replace(tmp, cfg_path)
PY
    if [ $? -eq 0 ]; then
      $json_mode || ok "  ${host_label}  ${tool}: updated command → ${new_path}"
      _repaired "${tool} ${host_label}: updated stale command to ${new_path}"
    else
      $json_mode || miss "  ${host_label}  ${tool}: failed to update config"
      _failed "${tool} ${host_label}: JSON write failed"
    fi
  }

  local cc_cfg="$HOME/.claude/settings.json"
  local cd_mac="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
  local cd_linux="$HOME/.config/Claude/claude_desktop_config.json"
  local oc_cfg="$HOME/.opencode.json"

  local _mcp_tool
  for _mcp_tool in tilth serena; do
    _repair_mcp_json "$_mcp_tool" "claude-code"    "$cc_cfg"
    _repair_mcp_json "$_mcp_tool" "claude-desktop" "$cd_mac"
    _repair_mcp_json "$_mcp_tool" "claude-desktop" "$cd_linux"
    _repair_mcp_json "$_mcp_tool" "opencode"       "$oc_cfg"
  done

  # ── 3. Codex TOML — stale commands flagged as manual only ────────────────
  local codex_cfg="$HOME/.codex/config.toml"
  if [ -f "$codex_cfg" ]; then
    for _mcp_tool in tilth serena; do
      local codex_cmd; codex_cmd=$(codex_mcp_command "$_mcp_tool" 2>/dev/null || echo "")
      [ -n "$codex_cmd" ] || continue
      if ! mcp_command_exists "$codex_cmd"; then
        $json_mode || warn "  codex  ${_mcp_tool}: stale '${codex_cmd}' — edit ~/.codex/config.toml manually"
        _skipped "${_mcp_tool} codex: stale command '${codex_cmd}' — edit ~/.codex/config.toml manually"
      fi
    done
  fi

  # ── 4. Summary ───────────────────────────────────────────────────────────
  if $json_mode; then
    python3 - "$repairs" "$failures" "$dry_run" \
      "REPAIRED_SEP" "${repaired[@]+"${repaired[@]}"}" \
      "FAILED_SEP"   "${failed[@]+"${failed[@]}"}" \
      "SKIPPED_SEP"  "${skipped[@]+"${skipped[@]}"}" << 'PY'
import json, sys
repairs  = int(sys.argv[1])
failures = int(sys.argv[2])
is_dry   = sys.argv[3] == "true"
repaired, failed, skipped, current = [], [], [], None
for a in sys.argv[4:]:
    if   a == "REPAIRED_SEP": current = repaired
    elif a == "FAILED_SEP":   current = failed
    elif a == "SKIPPED_SEP":  current = skipped
    elif current is not None: current.append(a)
result = {
    "repairs": repairs, "failures": failures,
    "repaired": repaired, "failed": failed, "skipped": skipped,
    "healthy": failures == 0,
}
if is_dry:
    result["dry_run"] = True
print(json.dumps(result, indent=2))
PY
  else
    echo ""
    echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"
    if [ "$failures" -eq 0 ] && [ "$repairs" -gt 0 ]; then
      echo -e "\n  ${GREEN}${BOLD}Repaired ${repairs} issue(s)${NC}\n"
    elif [ "$failures" -eq 0 ]; then
      echo -e "\n  ${GREEN}${BOLD}Nothing to repair — stack is healthy${NC}\n"
    else
      echo -e "\n  ${RED}${BOLD}${failures} repair(s) failed — manual action required:${NC}"
      local _f
      for _f in "${failed[@]}"; do
        echo -e "  ${RED}→${NC}  ${_f}"
      done
      echo ""
    fi
  fi

  return "$(( failures > 0 ))"
}

cmd_doctor() {
  local json_mode=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_mode=true; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local issues=0
  local -a findings=() compat_results=()
  _issue() { findings+=("$1"); issues=$(( issues + 1 )); }

  $json_mode || echo -e "\n${BOLD}token-diet doctor${NC}\n"

  # ── 1. Binaries ─────────────────────────────────────────────────────────────
  $json_mode || { echo -e "${BOLD}Binaries${NC}"; \
                  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"; }

  local rtk_ok=false tilth_ok=false serena_ok=false rtk_ver="" tilth_ver=""

  if check_cmd rtk && rtk --version &>/dev/null 2>&1; then
    rtk_ok=true
    rtk_ver=$(rtk --version 2>/dev/null | awk '{print $2}')
    $json_mode || ok "rtk     ${rtk_ver}   ${DIM}$(command -v rtk)${NC}"
    local _rtk_min; _rtk_min=$(_compat_min "rtk")
    if _semver_ok "$rtk_ver" "$_rtk_min"; then
      compat_results+=("rtk:ok:${rtk_ver}:${_rtk_min}")
    else
      $json_mode || warn "rtk ${rtk_ver} is below minimum ${_rtk_min} — upgrade: cargo install rtk"
      _issue "compat: rtk ${rtk_ver} below minimum ${_rtk_min}"
      compat_results+=("rtk:warn:${rtk_ver}:${_rtk_min}")
    fi
  else
    $json_mode || miss "rtk     not found  →  run: bash install.sh --rtk-only"
    _issue "rtk: binary missing"
  fi

  if check_cmd tilth && tilth --version &>/dev/null 2>&1; then
    tilth_ok=true
    tilth_ver=$(tilth --version 2>/dev/null | awk '{print $2}')
    $json_mode || ok "tilth   ${tilth_ver}   ${DIM}$(command -v tilth)${NC}"
    local _tilth_min; _tilth_min=$(_compat_min "tilth")
    if _semver_ok "$tilth_ver" "$_tilth_min"; then
      compat_results+=("tilth:ok:${tilth_ver}:${_tilth_min}")
    else
      $json_mode || warn "tilth ${tilth_ver} is below minimum ${_tilth_min} — upgrade: cargo install tilth"
      _issue "compat: tilth ${tilth_ver} below minimum ${_tilth_min}"
      compat_results+=("tilth:warn:${tilth_ver}:${_tilth_min}")
    fi
  else
    $json_mode || miss "tilth   not found  →  run: bash install.sh --tilth-only"
    _issue "tilth: binary missing"
  fi

  local uvx_ok=false uv_ok=false
  { check_cmd uvx && uvx --version &>/dev/null 2>&1; } && uvx_ok=true || true
  { check_cmd uv  && uv  --version &>/dev/null 2>&1; } && uv_ok=true  || true

  if $uvx_ok || $uv_ok || \
     docker image inspect token-diet/serena:latest &>/dev/null 2>&1; then
    serena_ok=true
    if $uvx_ok; then
      $json_mode || ok "serena  runtime: uvx   ${DIM}$(command -v uvx)${NC}"
    elif $uv_ok; then
      $json_mode || ok "serena  runtime: uv    ${DIM}$(command -v uv)${NC}"
    else
      $json_mode || ok "serena  runtime: docker image token-diet/serena:latest"
    fi
  else
    $json_mode || miss "serena  no runtime found  →  install uvx or build docker image"
    _issue "serena: no runtime (uvx/uv/docker)"
  fi

  # ── 2. RTK hooks ────────────────────────────────────────────────────────────
  $json_mode || { echo ""; echo -e "${BOLD}RTK hooks${NC}"; \
                  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"; }

  if $rtk_ok; then
    local rtk_show; rtk_show=$(rtk init --show 2>/dev/null || echo "")
    if [ -n "$rtk_show" ]; then
      local label
      while IFS= read -r line; do
        label="${line#*\] }"  # strip leading [STATUS] prefix
        case "$line" in
          \[ok\]*)
            $json_mode || ok "$label" ;;
          \[warn\]*)
            $json_mode || warn "$label"
            _issue "RTK hook warning: $label" ;;
          \[FAIL\]*)
            $json_mode || miss "$label"
            _issue "RTK hook failure: $label" ;;
          \[--\]*)
            $json_mode || dim "  (not configured) $label" ;;
        esac
      done <<< "$rtk_show"
    else
      $json_mode || warn "rtk init --show returned no output"
      _issue "RTK: could not read hook status"
    fi
  else
    $json_mode || dim "  (skipped — rtk not installed)"
  fi

  # ── 3. MCP registrations ────────────────────────────────────────────────────
  $json_mode || { echo ""; echo -e "${BOLD}MCP registrations${NC}"; \
                  echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"; }

  # tilth: delegate to `tilth doctor` which covers all 22 hosts
  local tilth_doctor_json=""
  if $tilth_ok; then
    tilth_doctor_json=$(tilth doctor --json 2>/dev/null || echo "")
    if [ -n "$tilth_doctor_json" ]; then
      if $json_mode; then
        : # folded into JSON output below
      else
        echo -e "  ${BOLD}tilth${NC}"
        echo "$tilth_doctor_json" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    hosts = d.get('hosts', {})
    found_any = False
    for host, info in sorted(hosts.items()):
        found_any = True
        if info.get('registered'):
            cmd = info.get('command', '')
            ok_flag = info.get('command_ok', True)
            mark = '\033[32m\u2713\033[0m' if ok_flag else '\033[33m!\033[0m'
            label = 'registered' if ok_flag else 'registered but command missing:'
            print(f'    {mark}  {host:<20} {label}   {cmd}')
        else:
            print(f'    \033[2m\u2013\033[0m  {host:<20} config exists \u2014 not registered')
    if not found_any:
        print('    (no host configs found)')
except Exception as e:
    print(f'    (could not parse tilth doctor output: {e})')
"
        echo ""
      fi
      # Feed issues from tilth doctor into our findings only when explicitly unhealthy
      local _tilth_healthy; _tilth_healthy=$(echo "$tilth_doctor_json" | python3 -c "import json,sys; d=json.load(sys.stdin); print('true' if d.get('healthy') else 'false')" 2>/dev/null || echo "unknown")
      if [ "$_tilth_healthy" = "false" ]; then
        _issue "tilth: not registered in any MCP host (run: tilth install <host>)"
      fi
    else
      # tilth doctor returned nothing (old binary without doctor subcommand) — soft skip
      $json_mode || dim "  tilth   (doctor subcommand not available — upgrade tilth to v0.6.0+)"
    fi
  else
    $json_mode || dim "  tilth   (skipped — binary not installed)"
  fi

  # serena: manual check for the four common hosts
  _doctor_check_mcp_json() {
    local tool="$1" host_label="$2" cfg="$3"
    [ -f "$cfg" ] || return 0  # host not installed — skip silently

    local registered
    registered=$(python3 - "$cfg" "$tool" << 'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    servers = d.get("mcpServers", {})
    key = next((k for k in servers if sys.argv[2].lower() in k.lower()), None)
    if key is None:
        sys.exit(1)
    v = servers[key]
    cmd = v.get("command", "")
    args = v.get("args", [])
    print(cmd + (" " + " ".join(str(a) for a in args) if args else ""))
except Exception:
    sys.exit(1)
PY
    2>/dev/null)

    if [ -n "$registered" ]; then
      local first_word; first_word=$(echo "$registered" | awk '{print $1}')
      if mcp_command_exists "$first_word"; then
        $json_mode || ok "  ${host_label}   registered   ${DIM}${registered}${NC}"
      else
        $json_mode || warn "  ${host_label}   registered but command missing: ${first_word}"
        _issue "${tool} ${host_label}: registered but '${first_word}' not in PATH"
      fi
    else
      $json_mode || miss "  ${host_label}   not registered  →  run: bash install.sh"
      _issue "${tool} ${host_label}: not registered"
    fi
  }

  _doctor_check_mcp_codex() {
    local tool="$1"
    [ -f "$HOME/.codex/config.toml" ] || return 0
    local codex_cmd; codex_cmd=$(codex_mcp_command "$tool" 2>/dev/null || echo "")
    if [ -n "$codex_cmd" ]; then
      if mcp_command_exists "$codex_cmd"; then
        $json_mode || ok "  codex       registered   ${DIM}${codex_cmd}${NC}"
      else
        $json_mode || warn "  codex       registered but command missing: ${codex_cmd}"
        _issue "${tool} codex: registered but '${codex_cmd}' not in PATH"
      fi
    else
      $json_mode || miss "  codex       not registered  →  run: bash install.sh"
      _issue "${tool} codex: not registered"
    fi
  }

  local cc_cfg="$HOME/.claude/settings.json"
  local cd_mac="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
  local cd_linux="$HOME/.config/Claude/claude_desktop_config.json"
  local oc_cfg="$HOME/.opencode.json"

  $json_mode || echo -e "  ${BOLD}serena${NC}"
  _doctor_check_mcp_json "serena" "claude-code"    "$cc_cfg"
  _doctor_check_mcp_json "serena" "claude-desktop" "$cd_mac"
  _doctor_check_mcp_json "serena" "claude-desktop" "$cd_linux"
  _doctor_check_mcp_json "serena" "opencode"       "$oc_cfg"
  _doctor_check_mcp_codex "serena"
  $json_mode || echo ""

  # ── 4. Summary ──────────────────────────────────────────────────────────────
  if $json_mode; then
    python3 - "$issues" "$tilth_doctor_json" \
      "FINDINGS_SEP" "${findings[@]+"${findings[@]}"}" \
      "COMPAT_SEP"   "${compat_results[@]+"${compat_results[@]}"}" << 'PY'
import json, sys

args = sys.argv[1:]
issues = int(args[0])
tilth_doctor_raw = args[1]
findings, compat_raw, current = [], [], None
for a in args[2:]:
    if a == "FINDINGS_SEP":  current = findings;   continue
    if a == "COMPAT_SEP":    current = compat_raw; continue
    if current is not None:  current.append(a)

compat = {}
for entry in compat_raw:
    parts = entry.split(":", 3)
    if len(parts) == 4:
        tool, status, ver, min_ver = parts
        compat[tool] = {"status": status, "version": ver, "min": min_ver}

tilth_mcp = None
if tilth_doctor_raw:
    try:
        tilth_mcp = json.loads(tilth_doctor_raw)
    except Exception:
        pass

out = {
    "issues": issues,
    "healthy": issues == 0,
    "findings": findings,
    "compat": compat,
}
if tilth_mcp is not None:
    out["tilth_mcp"] = tilth_mcp

print(json.dumps(out, indent=2))
PY
  else
    echo -e "${DIM}$(printf '%.0s─' {1..50})${NC}"
    if [ "$issues" -eq 0 ]; then
      echo -e "\n  ${GREEN}${BOLD}All checks passed — stack is healthy${NC}\n"
    else
      echo -e "\n  ${YELLOW}${BOLD}${issues} issue(s) found:${NC}"
      local f
      for f in "${findings[@]}"; do
        echo -e "  ${RED}→${NC}  ${f}"
      done
      echo -e "\n  Run ${BOLD}bash install.sh${NC} to repair most issues.\n"
    fi
  fi

  return "$(( issues > 0 ))"
}

cmd_help() {
  cat << EOF

${BOLD}token-diet${NC} — token optimization stack dashboard

${BOLD}USAGE${NC}
  token-diet [command]

${BOLD}COMMANDS${NC}
  gain              Show token savings dashboard across RTK + tilth + Serena  (default)
  health            Quick health check: tools responding + MCP hosts registered
  doctor            Structured diagnosis: binaries, RTK hooks, MCP registrations  [--json]
  repair            Fix what doctor finds: RTK hooks, stale MCP commands  [--dry-run] [--json]
  breakdown         Top commands by tokens saved  [--limit N]
  explain <cmd>     Token cost breakdown for a specific command
  budget <init|status>  Per-project token budget with warn/hard thresholds
  loops             Detect agent loop patterns (commands run 3+ times)
  route <task>      Suggest which tool (tilth/Serena/RTK) best fits the task
  leaks             Detect files read multiple times in RTK history
  test-first <file> Suggest test file counterpart for an implementation file
  strip [--stats] <file>  Strip comments from source file to reduce tokens
  diff-reads <file> Suggest line ranges to read based on recent git diff
  serena-gc         Detect and kill orphaned Serena/LSP processes  [--force]
  dashboard         Open live browser dashboard  [--port N]
  service <sub>     Manage always-on dashboard daemon  (install|uninstall|start|stop|status)
  version           Show installed versions of all three tools
  verify            Re-run installation verification
  no-rtk            Temporarily disable RTK hook (commands pass through unfiltered)
  use-rtk           Re-enable RTK hook
  uninstall         Remove all token-diet components  [--dry-run] [--force]
  --help            Show this help

${BOLD}TOOLS${NC}
  RTK    Command output compression       60-90% savings (tracked)
  tilth  AST-aware code reading           38-44% savings (structural)
  Serena LSP symbol navigation            fewer prompt turns (structural)

${BOLD}INSTALL${NC}
  bash install.sh             Install all tools
  bash install.sh --dry-run   Preview what would be installed

EOF
}

# --- Dispatch -----------------------------------------------------------------
case "${1:-gain}" in
  gain)              cmd_gain ;;
  health)            cmd_health ;;
  doctor)            shift; cmd_doctor "$@" ;;
  repair)            shift; cmd_repair "$@" ;;
  breakdown)         shift; cmd_breakdown "$@" ;;
  explain)           shift; cmd_explain "$@" ;;
  budget)            shift; cmd_budget "$@" ;;
  loops)             cmd_loops ;;
  dashboard)         shift; cmd_dashboard "$@" ;;
  service)           shift; cmd_service "$@" ;;
  version|versions)  cmd_version ;;
  verify)            cmd_verify ;;
  route)             shift; cmd_route "$@" ;;
  leaks)             cmd_leaks ;;
  test-first)        shift; cmd_test_first "$@" ;;
  strip)             shift; cmd_strip "$@" ;;
  diff-reads)        shift; cmd_diff_reads "$@" ;;
  serena-gc)         shift; cmd_serena_gc "$@" ;;
  uninstall)         shift; cmd_uninstall "$@" ;;
  no-rtk)            cmd_no_rtk ;;
  use-rtk)           cmd_use_rtk ;;
  --help|-h|help)    cmd_help ;;
  --version)         echo "token-diet $TD_VERSION" ;;
  *)  echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
