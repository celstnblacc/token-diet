#!/usr/bin/env python3
"""token-diet-dashboard — live browser dashboard for the token-diet stack.
stdlib only. Starts a local HTTP server, opens browser, Ctrl+C to stop.

Usage: token-diet dashboard [--port N]
"""
import datetime
import http.server
import json
import os
import pathlib
import subprocess
import sys
import threading
import webbrowser
from urllib.parse import urlparse

PORT = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[1:2] == ["--port"] else 7384

# ---------------------------------------------------------------------------
# Data collection
# ---------------------------------------------------------------------------

def run(cmd, **kw):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=10, **kw)
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None

def rtk_stats(data=None):
    if data is None:
        data = _get_rtk_daily()
    if not data:
        return None
    ver_raw = run(["rtk", "--version"])
    version = ver_raw.split()[-1] if ver_raw else None
    return {"version": version, "summary": data["summary"], "daily": data.get("daily", [])[-14:]}

def tilth_stats():
    ver = run(["tilth", "--version"])
    if not ver:
        return None
    hosts = _registered_hosts("tilth")
    return {"version": ver.split()[-1], "hosts": hosts}

def serena_stats():
    has_uvx    = run(["uvx", "--version"]) is not None
    has_docker = run(["docker", "image", "inspect", "token-diet/serena:latest"]) is not None
    if not has_uvx and not has_docker:
        return None
    mem_dir = pathlib.Path.home() / ".serena" / "memories"
    log_dir = pathlib.Path.home() / ".serena" / "logs"
    memories  = len(list(mem_dir.iterdir())) if mem_dir.exists() else 0
    log_days  = len(list(log_dir.iterdir())) if log_dir.exists() else 0
    hosts     = _registered_hosts("serena")
    mode      = "docker" if has_docker else "uvx"
    version   = None
    if has_docker:
        label = run(["docker", "inspect", "token-diet/serena:latest",
                     "--format", "{{index .Config.Labels \"org.opencontainers.image.version\"}}"])
        version = label.strip() if label and label.strip() else None
    elif has_uvx:
        ver_raw = run(["uvx", "serena", "--version"])
        version = ver_raw.split()[-1] if ver_raw else None
    return {"mode": mode, "version": version, "hosts": hosts, "memories": memories, "log_days": log_days}

def _registered_hosts(tool):
    found = []
    candidates = [
        (pathlib.Path.home() / ".claude" / "settings.json",              "claude-code"),
        (pathlib.Path.home() / "Library" / "Application Support" /
         "Claude" / "claude_desktop_config.json",                         "claude-desktop"),
        (pathlib.Path.home() / ".config" / "Claude" /
         "claude_desktop_config.json",                                     "claude-desktop"),
        (pathlib.Path.home() / ".opencode.json",                          "opencode"),
    ]
    for path, label in candidates:
        try:
            d = json.loads(path.read_text())
            if any(tool in k.lower() for k in d.get("mcpServers", {})):
                found.append(label)
        except Exception:
            pass
    codex = pathlib.Path.home() / ".codex" / "config.toml"
    if codex.exists() and tool in codex.read_text():
        found.append("codex")
    return list(dict.fromkeys(found))  # dedup, preserve order

_ALL_HOSTS = ["claude-code", "claude-desktop", "opencode", "codex"]

def _missing_hosts(tool):
    registered = set(_registered_hosts(tool))
    return [h for h in _ALL_HOSTS if h not in registered]

def _find_project_budget(home):
    """Walk up from cwd toward home looking for .token-budget. Returns Path or None."""
    d = pathlib.Path.cwd()
    while True:
        p = d / ".token-budget"
        if p.exists():
            return p
        if d == home:
            break
        parent = d.parent
        if parent == d:
            break
        d = parent
    return None

def _read_budget_file(path):
    try:
        return json.loads(path.read_text())
    except Exception:
        return None

def _get_rtk_total():
    """Fetch total input tokens from RTK. Returns 0 if RTK unavailable."""
    raw = run(["rtk", "gain", "--format", "json"])
    if not raw:
        return 0
    try:
        return json.loads(raw)["summary"]["total_input"]
    except Exception:
        return 0

def _get_rtk_daily():
    """Fetch full RTK daily JSON. Returns parsed dict or None if RTK unavailable."""
    raw = run(["rtk", "gain", "--daily", "--format", "json"])
    if not raw:
        return None
    try:
        return json.loads(raw)
    except Exception:
        return None

def _budget_entry(cfg, total_input, file_path):
    warn         = cfg.get("warn", 1500000)
    hard         = cfg.get("hard", 0)
    baseline     = cfg.get("baseline_tokens", 0)
    installed_at = cfg.get("installed_at", None)
    used         = max(0, total_input - baseline)
    unlimited    = hard == 0
    remaining    = None if unlimited else max(0, hard - used)
    pct          = round(used * 100 / hard, 1) if hard > 0 else 0
    warn_pct     = round(warn * 100 / hard, 1) if hard > 0 else 0
    status       = "ok" if used < warn else ("warn" if unlimited or used < hard else "hard")
    return {
        "warn": warn, "hard": hard, "used": used,
        "remaining": remaining, "pct": pct, "warn_pct": warn_pct,
        "status": status, "file": str(file_path),
        "installed_at": installed_at,
    }

def budget_stats(total_input=None):
    """Return active budget (project or global) plus global reference when an override is active.
    Auto-creates ~/.token-budget with defaults if missing."""
    home = pathlib.Path.home()
    global_path = home / ".token-budget"

    if total_input is None:
        total_input = _get_rtk_total()

    # Auto-create global if missing
    if not global_path.exists():
        global_path.write_text(
            json.dumps({
                "warn": 1500000, "hard": 0,
                "installed_at": datetime.date.today().isoformat(),
                "baseline_tokens": total_input,
            }, indent=2) + "\n"
        )

    project_path = _find_project_budget(home)
    # project_path == global_path means we found it AT $HOME, not a real override
    is_override = project_path is not None and project_path != global_path

    active_path = project_path if is_override else global_path
    active_cfg  = _read_budget_file(active_path)
    if active_cfg is None:
        return None

    result = _budget_entry(active_cfg, total_input, active_path)
    result["is_override"] = is_override

    if is_override:
        global_cfg = _read_budget_file(global_path)
        if global_cfg:
            g = _budget_entry(global_cfg, total_input, global_path)
            result["global"] = {
                "file": g["file"], "warn": g["warn"], "hard": g["hard"],
            }

    return result

def all_budget_files(total_input=None):
    """Scan home directory (max 3 levels) for all .token-budget files.
    Returns list of {file, warn, hard, status, used} sorted by path depth."""
    home = pathlib.Path.home()
    _SKIP = {'node_modules', '__pycache__', 'venv', '.venv', 'dist', 'build',
             'Library', '.Trash', '.cache', '.npm', '.cargo', '.rustup'}

    found = []
    for dirpath, dirnames, filenames in os.walk(str(home)):
        depth = dirpath[len(str(home)):].count(os.sep)
        if depth >= 3:
            dirnames.clear()
            continue
        dirnames[:] = [d for d in dirnames if not d.startswith('.') and d not in _SKIP]
        if '.token-budget' in filenames:
            found.append(pathlib.Path(dirpath) / '.token-budget')

    if not found:
        return []

    if total_input is None:
        total_input = _get_rtk_total()

    rows = []
    for p in sorted(found, key=lambda x: len(x.parts)):
        cfg = _read_budget_file(p)
        if not cfg:
            continue
        entry = _budget_entry(cfg, total_input, p)
        entry["file"]      = str(p).replace(str(home), "~")
        entry["unlimited"] = cfg.get("hard", 0) == 0
        rows.append(entry)
    return rows

def breakdown_stats(data=None, limit=10):
    """Top days by tokens saved — uses RTK daily data (per-command JSON not available)."""
    if data is None:
        data = _get_rtk_daily()
    if not data:
        return None
    try:
        daily = data.get("daily", [])
        if not daily:
            return None
        top = sorted(daily, key=lambda x: x.get("saved_tokens", 0), reverse=True)[:limit]
        return {"top_days": top}
    except Exception:
        return None

def loops_stats():
    """Per-command JSON not available in this RTK version."""
    return None

def leaks_stats():
    """Per-command JSON not available in this RTK version."""
    return None

def projection_stats(data=None):
    """Weekly token savings projection based on last 7 days of RTK daily data."""
    if data is None:
        data = _get_rtk_daily()
    if not data:
        return None
    try:
        daily = data.get("daily", [])
        if not daily:
            return None
        recent = daily[-7:]
        avg_saved = sum(day.get("saved_tokens", 0) for day in recent) / len(recent)
        avg_pct   = sum(day.get("savings_pct",  0) for day in recent) / len(recent)
        return {
            "avg_daily_saved":   round(avg_saved),
            "weekly_projection": round(avg_saved * 7),
            "avg_pct":           round(avg_pct, 1),
            "days_sampled":      len(recent),
        }
    except Exception:
        return None

def missing_hosts_stats():
    """Hosts where tilth/serena are not yet registered as MCP servers."""
    return {
        "tilth":  _missing_hosts("tilth"),
        "serena": _missing_hosts("serena"),
    }

def token_diet_version():
    """Self-version of the token-diet CLI."""
    raw = run(["token-diet", "--version"])
    if not raw:
        return None
    return raw.split()[-1]

def collect():
    daily_data  = _get_rtk_daily()
    total_input = daily_data["summary"]["total_input"] if daily_data else 0
    return {
        "version":       token_diet_version(),
        "rtk":           rtk_stats(daily_data),
        "tilth":         tilth_stats(),
        "serena":        serena_stats(),
        "breakdown":     breakdown_stats(daily_data),
        "budget":        budget_stats(total_input),
        "budgets":       all_budget_files(total_input),
        "loops":         loops_stats(),
        "leaks":         leaks_stats(),
        "projection":    projection_stats(daily_data),
        "missing_hosts": missing_hosts_stats(),
    }

