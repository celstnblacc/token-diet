#!/usr/bin/env python3
"""token-diet-dashboard — live browser dashboard for the token-diet stack.
stdlib only. Starts a local HTTP server, opens browser, Ctrl+C to stop.
"""
import datetime
import http.server
import json
import os
import pathlib
import subprocess
import sys
import threading
import webbrowser
import time
from urllib.parse import urlparse

PORT = 7384

# --- Memory Cache ------------------------------------------------------------
_CACHE = {"data": None, "expires": 0}
_CACHE_TTL = 30  # 30 seconds

def run(cmd, timeout=5):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip() if r.returncode == 0 else None
    except Exception:
        return None

def _get_rtk_daily():
    raw = run(["rtk", "gain", "--daily", "--format", "json"], timeout=15)
    if not raw: return None
    try: return json.loads(raw)
    except: return None

def _get_rtk_total():
    raw = run(["rtk", "gain", "--format", "json"], timeout=10)
    if not raw: return 0
    try: return json.loads(raw)["summary"]["total_input"]
    except: return 0

def rtk_stats(data):
    if not data: return None
    ver_raw = run(["rtk", "--version"])
    version = ver_raw.split()[-1] if ver_raw else None
    return {"version": version, "summary": data["summary"], "daily": data.get("daily", [])[-14:]}

def tilth_stats():
    ver = run(["tilth", "--version"])
    if not ver: return None
    hosts = _registered_hosts("tilth")
    return {"version": ver.split()[-1], "hosts": hosts}

def serena_stats():
    docker_image = run(["docker", "image", "inspect", "token-diet/serena:latest"], timeout=2) is not None
    uvx_version = run(["uvx", "--version"], timeout=2) is not None
    if not docker_image and not uvx_version: return None
    docker_running = False
    if docker_image:
        running_raw = run(["docker", "ps", "--filter", "ancestor=token-diet/serena:latest", "--format", "{{.ID}}"], timeout=2)
        docker_running = bool(running_raw)
    mem_dir = pathlib.Path.home() / ".serena" / "memories"
    log_dir = pathlib.Path.home() / ".serena" / "logs"
    memories  = len(list(mem_dir.iterdir())) if mem_dir.exists() else 0
    log_days  = len(list(log_dir.iterdir())) if log_dir.exists() else 0
    hosts     = _registered_hosts("serena")
    mode      = "docker-running" if docker_running else ("uvx" if uvx_version else "docker-image")
    return {"mode": mode, "version": None, "hosts": hosts, "memories": memories, "log_days": log_days}

def _registered_hosts(tool):
    found = []
    home = pathlib.Path.home()
    candidates = [
        (home / ".claude" / "settings.json", "claude-code"),
        (home / ".claude.json", "claude-code"),
        (home / "Library/Application Support/Claude/claude_desktop_config.json", "claude-desktop"),
        (home / ".config/Claude/claude_desktop_config.json", "claude-desktop"),
        (home / ".opencode.json", "opencode"),
        (home / ".gemini/settings.json", "gemini"),
    ]
    for path, label in candidates:
        if not path.exists(): continue
        try:
            d = json.loads(path.read_text())
            servers = d.get("mcpServers", {}) or d.get("mcp", {})
            if any(tool in k.lower() for k in servers): found.append(label)
        except: pass
    vscode = pathlib.Path(".vscode/mcp.json")
    if vscode.exists() and tool in vscode.read_text().lower(): found.append("vscode")
    codex = home / ".codex" / "config.toml"
    if codex.exists() and tool in codex.read_text().lower(): found.append("codex")
    return list(dict.fromkeys(found))

_ALL_HOSTS = ["claude-code", "claude-desktop", "opencode", "codex", "vscode", "gemini"]

def _missing_hosts(tool):
    registered = set(_registered_hosts(tool))
    return [h for h in _ALL_HOSTS if h not in registered]

def _read_budget_file(path):
    try: return json.loads(path.read_text())
    except: return None

def _budget_entry(cfg, total_input, file_path):
    warn = cfg.get("warn", 1500000); hard = cfg.get("hard", 0); baseline = cfg.get("baseline_tokens", 0)
    used = max(0, total_input - baseline); unlimited = (hard == 0)
    pct = int(used * 100 / hard) if not unlimited and hard > 0 else 0
    status = "ok" if used < warn else ("warn" if unlimited or used < hard else "hard")
    home_str = str(pathlib.Path.home())
    return {
        "warn": warn, "hard": hard, "used": used, "pct": pct, "status": status,
        "unlimited": unlimited,
        "installed_at": cfg.get("installed_at"),
        "file": str(file_path).replace(home_str, "~"),
    }

def budget_stats(total_input):
    home = pathlib.Path.home(); global_path = home / ".token-budget"
    project_path = None; d = pathlib.Path.cwd()
    while True:
        p = d / ".token-budget"
        if p.exists(): project_path = p; break
        if d == home: break
        parent = d.parent
        if parent == d: break
        d = parent
    active_path = project_path if (project_path and project_path != global_path) else global_path
    if not active_path.exists(): return None
    cfg = _read_budget_file(active_path)
    if not cfg: return None
    res = _budget_entry(cfg, total_input, active_path)
    res["is_override"] = (active_path != global_path)
    return res

def all_budget_files(total_input):
    home = pathlib.Path.home(); found = []
    _SKIP = {'node_modules', 'venv', '.venv', 'Library', '.Trash', '.cache', '.cargo'}
    for root, dirs, files in os.walk(str(home)):
        if root.count(os.sep) - str(home).count(os.sep) >= 2:
            dirs.clear(); continue
        dirs[:] = [d for d in dirs if not d.startswith('.') and d not in _SKIP]
        if '.token-budget' in files: found.append(pathlib.Path(root) / '.token-budget')
    rows = []
    for p in sorted(found):
        cfg = _read_budget_file(p)
        if cfg: rows.append(_budget_entry(cfg, total_input, p))
    return rows

def projection_stats(data):
    if not data: return None
    daily = data.get("daily", [])
    if not daily: return None
    recent = daily[-7:]
    avg_saved = sum(d.get("saved_tokens", 0) for d in recent) / len(recent)
    avg_pct = sum(d.get("savings_pct", 0) for d in recent) / len(recent)
    return {
        "avg_daily_saved": round(avg_saved),
        "weekly_projection": round(avg_saved * 7),
        "avg_pct": round(avg_pct, 1),
        "days_sampled": len(recent),
    }
def collect():
    now = time.time()
    if _CACHE["data"] and now < _CACHE["expires"]:
        return _CACHE["data"]

    daily_data = _get_rtk_daily()
    live_input = daily_data["summary"]["total_input"] if daily_data else _get_rtk_total()
    live_saved = daily_data["summary"]["total_saved"] if daily_data else 0
    live_cmds  = daily_data["summary"]["total_commands"] if daily_data else 0
    live_time  = daily_data["summary"]["total_time_ms"] if daily_data else 0

    arch_file = pathlib.Path.home() / ".config" / "token-diet" / "archived_stats.json"
    arch_input = 0; arch_saved = 0; arch_cmds = 0; arch_time = 0
    if arch_file.exists():
        try:
            a = json.loads(arch_file.read_text())
            arch_input = a.get("input", 0); arch_saved = a.get("saved", 0)
            arch_cmds = a.get("cmds", 0); arch_time = a.get("time_ms", 0)
        except: pass

    total_input = live_input + arch_input
    total_saved = live_saved + arch_saved
    total_cmds  = live_cmds + arch_cmds
    total_time  = live_time + arch_time
    total_pct   = round((total_saved / total_input * 100), 1) if total_input > 0 else 0.0

    alerts = []
    hist_file = pathlib.Path.home() / "Library/Application Support/rtk/history.db"
    if hist_file.exists():
        size_mb = hist_file.stat().st_size / (1024 * 1024)
        if size_mb > 10:
            alerts.append({"type": "warn", "msg": f"RTK history is large ({size_mb:.1f}MB) — run 'token-diet clean' to speed up dashboard"})

    # 5. Auto-Rotation Logic
    hist_file = pathlib.Path.home() / "Library/Application Support/rtk/history.db"
    if hist_file.exists():
        size_mb = hist_file.stat().st_size / (1024 * 1024)
        if size_mb > 10:
            # Trigger silent clean via subprocess
            try:
                subprocess.run(["token-diet", "clean"], capture_output=True, timeout=30)
            except subprocess.TimeoutExpired:
                alerts.append({"type": "warn", "msg": "History auto-rotation timed out after 30s — run 'token-diet clean' manually"})
            # Log it to dashboard alerts
            alerts.append({"type": "warn", "msg": f"History auto-rotated at {size_mb:.1f}MB to maintain performance. All savings carried forward."})
            # Force cache clear for next run
            _CACHE["data"] = None

    data = {
        "version": "1.7.1",
        "rtk": {
            "version": run(["rtk", "--version"]).split()[-1] if run(["rtk", "--version"]) else None,
            "summary": {
                "total_input": total_input, "total_saved": total_saved,
                "total_commands": total_cmds, "avg_savings_pct": total_pct,
                "total_time_ms": total_time
            },
            "daily": daily_data.get("daily", [])[-14:] if daily_data else []
        },
        "tilth": tilth_stats(),
        "serena": serena_stats(),
        "breakdown": {"top_days": sorted(daily_data.get("daily", []), key=lambda x: x.get("saved_tokens", 0), reverse=True)[:5]} if daily_data else None,
        "budget": budget_stats(total_input),
        "budgets": all_budget_files(total_input),
        "projection": projection_stats(daily_data),
        "missing_hosts": {"tilth": _missing_hosts("tilth"), "serena": _missing_hosts("serena")},
        "alerts": alerts,
        "cached_at": datetime.datetime.now().strftime("%H:%M:%S")
    }
    _CACHE["data"] = data
    _CACHE["expires"] = now + _CACHE_TTL
    return data

