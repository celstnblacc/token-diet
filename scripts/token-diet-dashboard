<script>
function fmt(n){if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return String(n)}
function fmtMs(ms){if(ms>=3600000)return Math.floor(ms/3600000)+'h '+Math.floor((ms%3600000)/60000)+'m';
  if(ms>=60000)return Math.floor(ms/60000)+'m '+Math.floor((ms%60000)/1000)+'s';
  if(ms>=1000)return (ms/1000).toFixed(1)+'s';return ms+'ms'}
function badge(ok){return ok?'<span class="badge ok">active</span>':'<span class="badge off">not installed</span>'}
function hosts(arr){if(!arr||!arr.length)return '<span class=none>none detected</span>';
  return arr.map(h=>'<span class=host>'+h+'</span>').join('')}
function missingHint(arr){if(!arr||!arr.length)return '';
  return '<div class=missing-hosts>\u26a0 Not registered in: '+arr.join(', ')+'</div>'}

function render(d){
  const verLabel=d.version?'v'+d.version:'';
  document.querySelector('h1').innerHTML='token-diet'+(verLabel?` <span style="font-size:13px;font-weight:500;color:#8b949e;background:#21262d;border:1px solid #30363d;border-radius:10px;padding:2px 8px;vertical-align:middle">${verLabel}</span>`:'');
  document.getElementById('ts').textContent='Last updated: '+new Date().toLocaleTimeString();
  const r=d.rtk, t=d.tilth, s=d.serena, p=d.projection;

  // --- Alert banner ---
  let alerts='';
  if(d.loops&&d.loops.loops&&d.loops.loops.length){
    const names=d.loops.loops.slice(0,3).map(l=>`<code>${l.cmd}</code> (${l.count}\xd7)`).join(', ');
    alerts+=`<div class="alert alert-danger">\u26a0\ufe0f ${d.loops.loops.length} loop pattern${d.loops.loops.length>1?'s':''} detected - ${names}</div>`;
  }
  if(d.leaks&&d.leaks.leaks&&d.leaks.leaks.length){
    const names=d.leaks.leaks.slice(0,3).map(l=>`<code>${l.file}</code> (${l.count}\xd7)`).join(', ');
    alerts+=`<div class="alert alert-warn">\u26a0 ${d.leaks.leaks.length} file${d.leaks.leaks.length>1?'s':''} read multiple times - ${names}</div>`;
  }
  document.getElementById('alerts').innerHTML=alerts;

  // --- Summary bar (fix: keep id=summary on replacement) ---
  let sh='<div class="summary" id=summary>';
  if(r){
    const sm=r.summary;
    sh+=`<div class=metric><div class=v>${fmt(sm.total_saved)}</div><div class=l>tokens saved (RTK)</div></div>`;
    sh+=`<div class=metric><div class=v>${sm.total_commands}</div><div class=l>commands filtered</div></div>`;
    sh+=`<div class=metric><div class=v>${sm.avg_savings_pct.toFixed(1)}%</div><div class=l>avg efficiency</div>
         <div class=eff-bar><div class=eff-fill style="width:${sm.avg_savings_pct.toFixed(1)}%"></div></div></div>`;
    sh+=`<div class=metric><div class=v>${fmtMs(sm.total_time_ms)}</div><div class=l>total exec time</div></div>`;
  } else {
    sh+='<div class=metric><div class=v style="color:#f85149">-</div><div class=l>RTK not installed</div></div>';
  }
  if(p){
    sh+=`<div class=metric><div class=v style="color:#39d353">${fmt(p.weekly_projection)}</div><div class=l>est. weekly savings</div></div>`;
  }
  const active=[r,t,s].filter(Boolean).length;
  sh+=`<div class=metric><div class=v style="color:${active===3?'#39d353':'#e3b341'}">${active}/3</div><div class=l>tools active</div></div>`;
  sh+='</div>';
  document.getElementById('summary').outerHTML=sh;

  // --- Cards ---
  let cards='';

  // RTK card
  cards+='<div class=card><h2 data-tip="Wraps every CLI command and filters/truncates its output before it reaches the LLM. Saves 60\u201390% of tokens on git, test runners, build tools, and any verbose command output.">RTK - output compression</h2>';
  if(r){
    const sm=r.summary;
    const rVer=r.version?` ${r.version}`:'';
    cards+=`<div class=tool>${badge(true)} RTK${rVer}</div>`;
    if(r.version) cards+=`<div class=stat><span class=sl>Version</span><span class=sv>${r.version}</span></div>`;
    cards+=`<div class=stat><span class=sl>Tokens in</span><span class=sv>${fmt(sm.total_input)}</span></div>`;
    cards+=`<div class=stat><span class=sl>Tokens saved</span><span class=sv>${fmt(sm.total_saved)}</span></div>`;
    cards+=`<div class=stat><span class=sl>Avg efficiency</span><span class=sv>${sm.avg_savings_pct.toFixed(1)}%</span></div>`;
    cards+=`<div class=stat><span class=sl>Commands</span><span class=sv>${sm.total_commands}</span></div>`;
    if(r.daily&&r.daily.length){
      const maxS=Math.max(...r.daily.map(x=>x.saved_tokens),1);
      cards+='<div class=bar-wrap><div class=bar-label>Daily saved tokens (last '+r.daily.length+' days)</div><div class=bars>';
      r.daily.forEach(day=>{
        const h=Math.max(4,Math.round((day.saved_tokens/maxS)*60));
        const col=day.savings_pct>=80?'#39d353':day.savings_pct>=60?'#e3b341':'#f85149';
        cards+=`<div class=bar style="height:${h}px;background:${col}"><span class=tip>${day.date}<br>${fmt(day.saved_tokens)} saved<br>${day.savings_pct.toFixed(1)}%</span></div>`;
      });
      cards+='</div></div>';
    }
  } else { cards+=badge(false)+'<p class=none style="margin-top:8px">Run: bash install.sh --rtk-only</p>'; }
  cards+='</div>';

  // tilth card
  cards+='<div class=card><h2 data-tip="AST = Abstract Syntax Tree. Instead of raw text, the parser understands code structure: functions, classes, imports and their boundaries. tilth uses tree-sitter to extract symbol outlines (names + signatures) without sending full file bodies. Reduces prompt size by 38\u201344%. Fast - no language server needed.">tilth - AST code reading</h2>';
  if(t){
    cards+=`<div class=tool>${badge(true)} tilth ${t.version}</div>`;
    cards+=`<div class=stat><span class=sl>Version</span><span class=sv>${t.version}</span></div>`;
    cards+=`<div class=stat><span class=sl>Layer</span><span class=sv>tree-sitter (fast)</span></div>`;
    cards+=`<div class=stat><span class=sl>Savings type</span><span class=sv>structural (prompt size)</span></div>`;
    cards+='<div class=hosts>'+hosts(t.hosts)+'</div>';
    if(d.missing_hosts) cards+=missingHint(d.missing_hosts.tilth);
  } else { cards+=badge(false)+'<p class=none style="margin-top:8px">Run: bash install.sh --tilth-only</p>'; }
  cards+='</div>';

  // Serena card
  cards+='<div class=card><h2 data-tip="LSP = Language Server Protocol. A language server understands your codebase deeply: go-to-definition, find-references, call graphs, cross-file symbols. Serena exposes this to the LLM so it navigates by meaning instead of reading whole files - fewer turns, smaller prompts.">Serena - LSP navigation</h2>';
  if(s){
    const sVer=s.version?` ${s.version}`:'';
    cards+=`<div class=tool>${badge(true)} Serena${sVer} (${s.mode})</div>`;
    cards+=`<div class=stat><span class=sl>Mode</span><span class=sv>${s.mode}</span></div>`;
    if(s.mode==='docker-image') cards+=`<div class=stat><span class=sl>Status</span><span class=sv style="color:#e3b341">image present, container not running</span></div>`;
    if(s.mode==='docker-running') cards+=`<div class=stat><span class=sl>Status</span><span class=sv style="color:#39d353">docker container running</span></div>`;
    if(s.mode==='uvx') cards+=`<div class=stat><span class=sl>Status</span><span class=sv>uvx runtime available</span></div>`;
    if(s.version) cards+=`<div class=stat><span class=sl>Version</span><span class=sv>${s.version}</span></div>`;
    cards+=`<div class=stat><span class=sl>Memories</span><span class=sv>${s.memories} files</span></div>`;
    cards+=`<div class=stat><span class=sl>Session logs</span><span class=sv>${s.log_days} days</span></div>`;
    cards+=`<div class=stat><span class=sl>Savings type</span><span class=sv>structural (fewer turns)</span></div>`;
    cards+='<div class=hosts>'+hosts(s.hosts)+'</div>';
    if(d.missing_hosts) cards+=missingHint(d.missing_hosts.serena);
  } else { cards+=badge(false)+'<p class=none style="margin-top:8px">Run: bash install.sh --serena-only</p>'; }
  cards+='</div>';

  // One full card per .token-budget file
  if(d.budgets&&d.budgets.length){
    d.budgets.forEach(b=>{
      const sc=b.status==='ok'?'ok':b.status==='warn'?'warn':'off';
      const bc=b.status==='ok'?'#39d353':b.status==='warn'?'#e3b341':'#f85149';
      const hard=b.unlimited?'unlimited':fmt(b.hard);
      const remaining=b.unlimited?'unlimited':fmt(Math.max(0,b.hard-b.used));
      cards+=`<div class=card><h2 data-tip="Per-project token spending limit. Warn threshold triggers a yellow alert. Hard stop (0 = unlimited) blocks further usage. Stored in .token-budget - cascades from project folder up to ~/.token-budget global default.">Token Budget</h2>`;
      cards+=`<div class=tool><span class="badge ${sc}">${b.status.toUpperCase()}</span></div>`;
      cards+=`<div class=stat><span class=sl>Used</span><span class=sv>${fmt(b.used)}</span></div>`;
      cards+=`<div class=stat><span class=sl>Warn at</span><span class=sv>${fmt(b.warn)}</span></div>`;
      cards+=`<div class=stat><span class=sl>Hard stop</span><span class=sv>${hard}</span></div>`;
      cards+=`<div class=stat><span class=sl>Remaining</span><span class=sv>${remaining}</span></div>`;
      if(!b.unlimited){
        const fillW=Math.min(100,b.pct);
        cards+=`<div class=bar-wrap><div class=bar-label>${b.pct}% of budget used</div>`;
        cards+=`<div class=budget-track><div class=budget-fill style="width:${fillW}%;background:${bc}"></div></div></div>`;
      }
      const since=b.installed_at?` - since ${b.installed_at}`:'';
      cards+=`<div style="margin-top:10px;font-size:11px;color:#8b949e">${b.file}${since}</div>`;
      cards+='</div>';
    });
  } else {
    cards+='<div class=card><h2>Token Budget</h2>';
    cards+='<p class=none style="margin-top:8px">No budget set</p>';
    cards+='<p style="margin-top:8px;font-size:12px;color:#8b949e">Run: <code>token-diet budget init</code></p>';
    cards+='</div>';
  }

  // Breakdown card (top days by tokens saved)
  cards+='<div class=card><h2 data-tip="Top days ranked by RTK tokens saved. Each bar in the RTK card represents one day. Green = 80%+ efficiency, yellow = 60\u201380%, red = below 60%.">Top days by tokens saved</h2>';
  if(d.breakdown&&d.breakdown.top_days&&d.breakdown.top_days.length){
    cards+='<table class=cmd-table><tr><th>Date</th><th>Saved</th><th>Eff</th><th>Cmds</th></tr>';
    d.breakdown.top_days.slice(0,5).forEach(day=>{
      const pct=day.savings_pct||0;
      const col=pct>=80?'#39d353':pct>=60?'#e3b341':'#f85149';
      cards+=`<tr><td class=cmd-name>${day.date}</td><td>${fmt(day.saved_tokens)}</td><td style="color:${col}">${pct.toFixed(0)}%</td><td>${day.commands}</td></tr>`;
    });
    cards+='</table>';
  } else {
    cards+='<p class=none style="margin-top:8px">No RTK history yet</p>';
  }
  cards+='</div>';

  document.getElementById('cards').innerHTML=cards;
  document.getElementById('rf').textContent='Auto-refreshes every 30s - Ctrl+C in terminal to stop';
}

async function refresh(){
  try{const r=await fetch('/api/stats');render(await r.json())}
  catch(e){document.getElementById('ts').textContent='Error fetching stats: '+e}
}
refresh();setInterval(refresh,30000);
</script></body></html>"""

class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args): pass
    def do_GET(self):
        if self.path == '/api/stats':
            self.send_response(200); self.send_header('Content-Type', 'application/json'); self.end_headers()
            self.wfile.write(json.dumps(collect()).encode())
        else:
            self.send_response(200); self.send_header('Content-Type', 'text/html'); self.end_headers()
            self.wfile.write(HTML.encode())

def main():
    url = f"http://127.0.0.1:{PORT}"
    try:
        server = http.server.HTTPServer(('127.0.0.1', PORT), Handler)
    except OSError as e:
        holder = run(["lsof", "-tiTCP:%d" % PORT, "-sTCP:LISTEN"]) or "unknown"
        print(f"token-diet-dashboard: cannot bind {url} ({e}).", file=sys.stderr)
        print(f"  Port {PORT} is held by PID {holder}. It may already be serving at {url}.", file=sys.stderr)
        print(f"  To replace it: kill {holder} && token-diet-dashboard", file=sys.stderr)
        sys.exit(1)
    print(f"token-diet-dashboard serving at {url} (Ctrl+C to stop)", flush=True)
    try:
        webbrowser.open(url)
    except Exception:
        pass
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\ntoken-diet-dashboard: stopped.", file=sys.stderr)
        server.server_close()

if __name__ == "__main__":
    main()
